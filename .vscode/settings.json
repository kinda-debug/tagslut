{
    "python.analysis.autoImportCompletions": true,
    "chatgpt.openOnStartup": true,
    "sqltools.useNodeRuntime": true,
    "sqltools.connections": [
        {
            "previewLimit": 50,
            "driver": "SQLite",
            "name": "music",
            "database": "${workspaceFolder:dedupe_repo_reclone}/music.db"
        },
        {
            "previewLimit": 50,
            "driver": "SQLite",
            "name": "library",
            "database": "${workspaceFolder:dedupe_repo_reclone}/artifacts/db/library.db"
        }
    ],
    "markdown.validate.enabled": true,
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.db": "sql-viewer.sqliteViewer",
        "*.csv": "sqlite-viewer.option",
        "file:/**/*.xlsx": "jupyter-data-wrangler",
        "*.md": "markdown-preview-enhanced",
        "file:/**/*.csv": "jupyter-data-wrangler"
    }
}