# Tagslut Environment Configuration
# Copy this file to .env and customize for your system

# ============================================================================
# DATABASE (source of truth)
# ============================================================================
# `TAGSLUT_DB` is the canonical database path. Export this from your `.env`
# before running `tagslut` (or add it to your shell profile).
TAGSLUT_DB=/path/to/your/music_v3.db

# ============================================================================
# VOLUMES (auto-populated from zones.yaml if available)
# ============================================================================
# Your volumes contain mixed content (dupes, unique, corrupt)
# Zones are determined by scan results, not volume location
# These are auto-extracted from ~/.config/tagslut/zones.yaml by auto_env.py

# Zone-based volumes (auto-populated)
VOLUME_STAGING=/path/to/staging
VOLUME_SUSPECT=/path/to/suspect
VOLUME_QUARANTINE=/path/to/quarantine
LIBRARY_ROOT=/path/to/flac_library
VOLUME_LIBRARY=$LIBRARY_ROOT

# ============================================================================
# ARTIFACTS & LOGS
# ============================================================================
TAGSLUT_ARTIFACTS=/path/to/tagslut/artifacts
TAGSLUT_REPORTS=/path/to/tagslut/artifacts/reports

# ============================================================================
# SCAN SETTINGS
# ============================================================================
SCAN_WORKERS=8
SCAN_PROGRESS_INTERVAL=100
SCAN_CHECK_INTEGRITY=true
SCAN_CHECK_HASH=true
SCAN_INCREMENTAL=true

# ============================================================================
# DECISION SETTINGS
# ============================================================================
# Auto-approve high-confidence decisions
AUTO_APPROVE_THRESHOLD=0.95

# Quarantine retention (days before eligible for deletion)
QUARANTINE_RETENTION_DAYS=30

# Quality preferences
PREFER_HIGH_BITRATE=true
PREFER_HIGH_SAMPLE_RATE=true
PREFER_VALID_INTEGRITY=true

# ============================================================================
# DJ LIBRARY
# ============================================================================
DJ_MP3_ROOT=/path/to/dj_library_mp3
DJ_LIBRARY_ROOT=$LIBRARY_ROOT
