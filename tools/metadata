#!/usr/bin/env bash
set -euo pipefail
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_wrapper_common.sh"
ts_wrapper_bootstrap "${BASH_SOURCE[0]}"
PYTHON_BIN="$(ts_repo_python)"
BASE="$TAGSLUT_TOOLS_DIR/metadata_scripts"
PY="$BASE/onetagger_workflow.py"
AUDIT="$BASE/metadata_audit.py"
NORM="$BASE/normalize_genres.py"
TAGNORM="$BASE/tag_normalized_genres.py"
TAGVALS="$BASE/tag_values_audit.py"
LEX="$BASE/lexicon_export.py"
LEXCMP="$BASE/lexicon_compare.py"
SYNC="$BASE/sync_tags_from_files.py"

cmd="${1:-}"
if [[ -z "$cmd" ]]; then
  echo "Usage: tools/metadata <full|build|run|tag|audiofeatures|audit|metadata|normalize-genres|tag-genres|audit-tags|export-lexicon|compare-lexicon|sync-tags> [args...]"
  exit 1
fi
shift

case "$cmd" in
  full)
    "$PYTHON_BIN" "$PY" sync --metadata-after-isrc "$@"
    LIB_ROOT="${LIBRARY_ROOT:-/Volumes/MUSIC/LIBRARY}"
    "$PYTHON_BIN" "$PY" audiofeatures --path "$LIB_ROOT"
    ;;
  build)
    exec "$PYTHON_BIN" "$PY" build "$@"
    ;;
  run)
    exec "$PYTHON_BIN" "$PY" run "$@"
    ;;
  tag)
    exec "$PYTHON_BIN" "$PY" sync --metadata-after-isrc "$@"
    ;;
  audiofeatures)
    exec "$PYTHON_BIN" "$PY" audiofeatures "$@"
    ;;
  metadata)
    exec "$PYTHON_BIN" "$PY" metadata "$@"
    ;;
  audit)
    exec "$PYTHON_BIN" "$AUDIT" "$@"
    ;;
  normalize-genres)
    exec "$PYTHON_BIN" "$NORM" "$@"
    ;;
  tag-genres)
    exec "$PYTHON_BIN" "$TAGNORM" "$@"
    ;;
  audit-tags)
    exec "$PYTHON_BIN" "$TAGVALS" "$@"
    ;;
  export-lexicon)
    exec "$PYTHON_BIN" "$LEX" "$@"
    ;;
  compare-lexicon)
    exec "$PYTHON_BIN" "$LEXCMP" "$@"
    ;;
  sync-tags)
    exec "$PYTHON_BIN" "$SYNC" "$@"
    ;;
  *)
    echo "Unknown command: $cmd"
    exit 1
    ;;
esac
