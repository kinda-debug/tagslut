#!/usr/bin/env bash
# get — Unified intake/download entrypoint for Tidal, Beatport, and Deezer URLs
#
# Routes URLs to the appropriate workflow based on domain:
#   - tidal.com    → tools/tiddl (TIDDL wrapper)
#   - beatport.com → tools/get-sync (prefilter + download missing + m3u)
#   - deezer.com   → tools/deemix (Deezer wrapper + auto-register)
#
# Usage:
#   tools/get [--sync|--synch|--simple] <url> [extra-args...]
#
# Examples:
#   tools/get https://tidal.com/browse/playlist/12345
#   tools/get https://www.beatport.com/release/some-release/12345
#   tools/get https://listen.tidal.com/album/12345 --quality high
#
# After downloading, register to inventory and generate M3U:
#   tagslut index register <download-path> --source <tidal|bpdl>
#   tagslut report m3u <download-path>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TIDDL_WRAPPER="$SCRIPT_DIR/tiddl"
DEEMIX_WRAPPER="$SCRIPT_DIR/deemix"
BPDL_BIN="$SCRIPT_DIR/beatportdl/bpdl/bpdl"
GET_INTAKE="$SCRIPT_DIR/get-intake"
GET_SYNC="$SCRIPT_DIR/get-sync"
GET_REPORT="$SCRIPT_DIR/get-report"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_LOADER="$SCRIPT_DIR/_load_env.sh"

if [[ -f "$ENV_LOADER" ]]; then
    # Load repo-local .env so wrapper commands see TAGSLUT_DB and volume roots.
    # shellcheck disable=SC1090
    source "$ENV_LOADER"
    load_workspace_env "$REPO_ROOT"
fi

usage() {
    echo "3-command Beatport workflow:"
    echo "  tools/get <beatport-url>         download missing + build playlist"
    echo "  tools/get-sync <beatport-url>    same flow (explicit sync)"
    echo "  tools/get-report <beatport-url>  report only, no download"
    echo ""
    echo "General usage: tools/get [--sync|--synch|--simple] <url> [extra-args...]"
    echo "  --sync/--synch: provider sync workflow"
    echo "  --simple: downloader-only behavior"
    echo "Use tools/get-help for the tiny version of this help."
    exit 1
}

if [[ $# -lt 1 ]]; then
    usage
fi

MODE="auto"
if [[ "$1" == "--sync" || "$1" == "--synch" ]]; then
    MODE="sync"
    shift
elif [[ "$1" == "--simple" ]]; then
    MODE="simple"
    shift
fi

if [[ $# -lt 1 ]]; then
    usage
fi

URL="$1"
shift

# Route based on domain
if [[ "$URL" == *"tidal.com"* ]]; then
    if [[ ! -x "$GET_INTAKE" ]]; then
        echo "Error: get-intake not found or not executable at: $GET_INTAKE" >&2
        exit 1
    fi
    cd "$REPO_ROOT"
    if [[ "$MODE" == "simple" ]]; then
        exec "$TIDDL_WRAPPER" "$URL" "$@"
    fi

    PRECHECK_ENABLED=1
    DB_PATH=""
    INTAKE_ARGS=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --missing-only)
                shift
                ;;
            --allow-duplicates)
                PRECHECK_ENABLED=0
                shift
                ;;
            --db)
                [[ $# -ge 2 ]] || { echo "Error: --db requires a value" >&2; exit 2; }
                DB_PATH="$2"
                shift 2
                ;;
            --)
                shift
                INTAKE_ARGS+=("$@")
                break
                ;;
            *)
                INTAKE_ARGS+=("$1")
                shift
                ;;
        esac
    done
    CMD=("$GET_INTAKE" --source tidal --missing-policy download --execute --m3u)
    if [[ "$PRECHECK_ENABLED" -eq 0 ]]; then
        CMD+=(--no-precheck)
    fi
    if [[ -n "$DB_PATH" ]]; then
        CMD+=(--db "$DB_PATH")
    fi
    CMD+=("$URL")
    if [[ ${#INTAKE_ARGS[@]} -gt 0 ]]; then
        CMD+=("${INTAKE_ARGS[@]}")
    fi
    exec "${CMD[@]}"

elif [[ "$URL" == *"beatport.com"* ]]; then
    if [[ ! -x "$GET_SYNC" ]]; then
        echo "Error: get-sync not found or not executable at: $GET_SYNC" >&2
        exit 1
    fi
    cd "$REPO_ROOT"
    if [[ "$MODE" == "simple" ]]; then
        if [[ ! -x "$BPDL_BIN" ]]; then
            echo "Error: BeatportDL binary not found or not executable at: $BPDL_BIN" >&2
            exit 1
        fi
        exec "$BPDL_BIN" "$URL" "$@"
    fi

    if [[ $# -eq 0 ]]; then
        exec "$GET_SYNC" "$URL"
    fi

    if [[ "$1" == "--report" ]]; then
        shift
        if [[ ! -x "$GET_REPORT" ]]; then
            echo "Error: get-report not found or not executable at: $GET_REPORT" >&2
            exit 1
        fi
        exec "$GET_REPORT" "$URL" "$@"
    fi

    if [[ "$1" == "--raw-bpdl" ]]; then
        shift
        if [[ ! -x "$BPDL_BIN" ]]; then
            echo "Error: BeatportDL binary not found or not executable at: $BPDL_BIN" >&2
            exit 1
        fi
        exec "$BPDL_BIN" "$URL" "$@"
    fi

    echo "Info: extra args detected; using get-sync compatibility mode." >&2
    exec "$GET_SYNC" "$URL" "$@"

elif [[ "$URL" == *"deezer.com"* || "$URL" == *"dzr.page.link"* ]]; then
    if [[ ! -x "$DEEMIX_WRAPPER" ]]; then
        echo "Error: deemix wrapper not found or not executable at: $DEEMIX_WRAPPER" >&2
        exit 1
    fi
    cd "$REPO_ROOT"
    exec "$DEEMIX_WRAPPER" "$URL" "$@"

else
    echo "Error: Unrecognized URL domain: $URL" >&2
    echo "Supported domains: tidal.com, beatport.com, deezer.com" >&2
    exit 1
fi
