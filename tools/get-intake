#!/usr/bin/env bash
# get-intake â€” download + fast tagslut intake for EDM-friendly workflows
#
# Pipeline:
#  1) Download via tools/get (optional)
#  2) Quick duplicate check via tagslut index check (strict, non-interactive)
#  3) Fast trust scan + integrity registration
#  4) Cross-root fingerprint audit against final library
#  5) Build promote/stash/quarantine plans
#  6) Optionally execute move plans (move-only semantics)
#
# Default behavior is safe: plans only (no moves) unless --execute is passed.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

GET_BIN="$SCRIPT_DIR/get"
SCAN_SCRIPT="$SCRIPT_DIR/review/scan_with_trust.py"
AUDIT_SCRIPT="$SCRIPT_DIR/review/audio_dupe_audit.py"
PLAN_SCRIPT="$SCRIPT_DIR/review/plan_fpcalc_promote_unique_to_final_library.py"
MOVE_SCRIPT="$SCRIPT_DIR/review/move_from_plan.py"
BEATPORT_PREFILTER_SCRIPT="$SCRIPT_DIR/review/beatport_prefilter.py"
BPDL_BIN="$SCRIPT_DIR/beatportdl/bpdl/bpdl"
BPDL_CONFIG="$SCRIPT_DIR/beatportdl/bpdl/beatportdl-config.yml"

AUTO_DB_AMBIGUOUS=0
AUTO_DB_CANDIDATES=()

usage() {
  cat <<'EOF'
Usage:
  tools/get-intake [options] <url> [-- downloader-args...]
  tools/get-intake --no-download --batch-root <path> [options]
  tools/get-intake --m3u-only (--url <beatport-url> | --playlist-file <file>) [options]
  tools/get-intake <beatport-url>   # auto: m3u-only with defaults when --batch-root omitted

Options:
  --batch-root PATH    Download batch root to process (required)
  --source TEXT        Source label (bpdl|tidal). Auto-inferred from URL if omitted.
  --url URL            Source URL (alternative to positional URL)
  --db PATH            SQLite DB path (default: $TAGSLUT_DB or auto-detected tagslut_db epoch; errors if ambiguous)
  --library-root PATH  Final library root (default: $LIBRARY_ROOT or /Volumes/MUSIC/LIBRARY)
  --fix-root PATH      FIX root (default: $FIX_ROOT or /Volumes/MUSIC/FIX)
  --out-dir PATH       Output directory for plans (default: artifacts/compare)
  --workers N          Fingerprint workers (default: 7)
  --trust N            Pre-scan trust score 0..3 (default: 3)
  --trust-post N       Post-scan trust score 0..3 (default: 3)
  --library-tag TEXT   Library tag used in scan_with_trust (default: INTAKE)
  --execute            Execute move plans (default: dry-run planning only)
  --m3u                Generate Roon-friendly merged M3U from promoted files
  --m3u-dir PATH       M3U output dir (default: library root when --m3u)
  --m3u-only           Only generate merged M3U (skip download/scan/move stages)
  --playlist-file PATH Build M3U from playlist file (.m3u/.m3u8/.txt/.csv/.json)
  --missing-policy MODE
                       Missing handling for --m3u-only: ask|report|skip|download (default: report)
  --no-download        Skip downloader step; process existing batch root
  --skip-mgmt-check    Skip quick duplicate check stage (legacy flag name)
  --skip-beatport-prefilter
                       Skip fast metadata prefilter before Beatport download
  --prefilter-margin-ms N
                       Duration tolerance for prefilter (default: 4000)
  -h, --help           Show this help

Examples:
  tools/get-intake "https://www.beatport.com/chart/.../12345"

  tools/get-intake --batch-root "$STAGING_ROOT/beatport" \
    "https://www.beatport.com/release/.../12345"

  tools/get-intake --no-download --batch-root "$STAGING_ROOT/clean" --execute

  tools/get-intake --m3u-only --m3u --url "https://www.beatport.com/chart/.../12345"
EOF
}

err() {
  echo "ERROR: $*" >&2
  exit 2
}

step() {
  local idx="$1"
  local total="$2"
  local label="$3"
  echo
  echo "[$idx/$total] $label"
}

run_cmd() {
  printf 'â†’ '
  printf '%q ' "$@"
  printf '\n'
  "$@"
}

safe_m3u_name() {
  local value="${1:-}"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g')"
  [[ -n "$value" ]] || value="playlist"
  echo "$value"
}

playlist_label_from_url() {
  local clean="${1%%\?*}"
  clean="${clean%/}"
  local last="${clean##*/}"
  local parent="${clean%/*}"
  local slug="${parent##*/}"

  case "$slug" in
    chart|release|releases|playlist|playlists|track|tracks|library|"")
      slug=""
      ;;
  esac

  if [[ -z "$slug" ]]; then
    slug="beatport-${last:-playlist}"
  fi
  safe_m3u_name "$slug"
}

rename_latest_m3u_from_marker() {
  local m3u_dir="$1"
  local marker_file="$2"
  local base_name="$3"

  [[ -d "$m3u_dir" ]] || return 0
  [[ -f "$marker_file" ]] || return 0
  [[ -n "$base_name" ]] || return 0

  local latest_new_m3u
  latest_new_m3u="$(find "$m3u_dir" -maxdepth 1 -type f -name '*.m3u' -newer "$marker_file" -print | sort | tail -n1 || true)"
  [[ -n "$latest_new_m3u" ]] || return 0

  local target="$m3u_dir/$base_name.m3u"
  if [[ "$latest_new_m3u" != "$target" ]]; then
    if [[ -f "$latest_new_m3u" ]]; then
      mv -f "$latest_new_m3u" "$target" || true
      if [[ -f "$target" ]]; then
        echo "Named playlist: $target"
      fi
    fi
  fi
}

bpdl_downloads_dir_from_config() {
  if [[ ! -f "$BPDL_CONFIG" ]]; then
    echo ""
    return 0
  fi
  local raw
  raw="$(sed -n 's/^downloads_directory:[[:space:]]*//p' "$BPDL_CONFIG" | head -n1)"
  raw="${raw%\"}"
  raw="${raw#\"}"
  raw="${raw%\'}"
  raw="${raw#\'}"
  echo "$raw"
}

autodetect_db_path() {
  local candidates=()

  if [[ -d "$REPO_ROOT/../tagslut_db" ]]; then
    while IFS= read -r file; do
      [[ -n "$file" ]] && candidates+=("$file")
    done < <(find "$REPO_ROOT/../tagslut_db" -type f \( -name music.db -o -name music_v2.db -o -name music_v3.db \) 2>/dev/null || true)
  fi

  if [[ -d "$HOME/Projects/tagslut_db" ]]; then
    while IFS= read -r file; do
      [[ -n "$file" ]] && candidates+=("$file")
    done < <(find "$HOME/Projects/tagslut_db" -type f \( -name music.db -o -name music_v2.db -o -name music_v3.db \) 2>/dev/null || true)
  fi

  if [[ ${#candidates[@]} -eq 0 ]]; then
    AUTO_DB_AMBIGUOUS=0
    AUTO_DB_CANDIDATES=()
    echo ""
    return 0
  fi

  AUTO_DB_CANDIDATES=("${candidates[@]}")

  if [[ ${#candidates[@]} -gt 1 ]]; then
    AUTO_DB_AMBIGUOUS=1
    echo ""
    return 0
  fi

  AUTO_DB_AMBIGUOUS=0
  echo "${candidates[0]}"
}

ensure_bpdl_download_target() {
  local target
  target="$(bpdl_downloads_dir_from_config)"
  if [[ -z "$target" ]]; then
    return 0
  fi

  local parent
  parent="$(dirname "$target")"
  if [[ ! -d "$parent" ]]; then
    err "Beatport downloads_directory parent is missing: $parent (from $BPDL_CONFIG). Mount the volume or update downloads_directory."
  fi

  mkdir -p "$target" || err "Cannot create Beatport downloads_directory: $target"
  [[ -d "$target" ]] || err "Beatport downloads_directory is not accessible: $target"
}

run_bpdl_batch() {
  local url_list="$1"
  local log_file="$2"
  shift 2
  local extra_args=("$@")

  ensure_bpdl_download_target

  local supports_quit=0
  if "$BPDL_BIN" -h 2>&1 | grep -q -- "-q"; then
    supports_quit=1
  fi

  if [[ "$supports_quit" -eq 1 ]]; then
    if [[ ${#extra_args[@]} -gt 0 ]]; then
      run_cmd "$BPDL_BIN" -q "${extra_args[@]}" "$url_list"
    else
      run_cmd "$BPDL_BIN" -q "$url_list"
    fi
    return 0
  fi

  echo "bpdl '-q' not supported by this binary; using compatibility mode."
  set +e
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    printf 'â†’ '
    printf '%q ' "$BPDL_BIN" "${extra_args[@]}" "$url_list"
    printf '\n'
    "$BPDL_BIN" "${extra_args[@]}" "$url_list" < /dev/null 2>&1 | tee "$log_file"
  else
    printf 'â†’ '
    printf '%q ' "$BPDL_BIN" "$url_list"
    printf '\n'
    "$BPDL_BIN" "$url_list" < /dev/null 2>&1 | tee "$log_file"
  fi
  local bpdl_code=${PIPESTATUS[0]}
  set -e

  if [[ "$bpdl_code" -ne 0 ]]; then
    if grep -q "Error reading input string: EOF" "$log_file"; then
      echo "bpdl exited after EOF prompt in non-interactive mode; continuing."
      return 0
    fi
    echo "bpdl failed (exit=$bpdl_code). See log: $log_file" >&2
    return "$bpdl_code"
  fi

  return 0
}

infer_source() {
  local url="$1"
  case "$url" in
    *beatport.com*) echo "bpdl" ;;
    *tidal.com*) echo "tidal" ;;
    *) echo "" ;;
  esac
}

DOWNLOAD=1
EXECUTE=0
SKIP_MGMT_CHECK=0
SKIP_BEATPORT_PREFILTER=0
M3U_MODE=0
M3U_ONLY=0

URL=""
BATCH_ROOT=""
SOURCE=""
DB_PATH="${TAGSLUT_DB:-}"
LIBRARY_ROOT="${LIBRARY_ROOT:-/Volumes/MUSIC/LIBRARY}"
FIX_ROOT="${FIX_ROOT:-/Volumes/MUSIC/FIX}"
OUT_DIR="$REPO_ROOT/artifacts/compare"
WORKERS=7
TRUST=3
TRUST_POST=3
LIBRARY_TAG="INTAKE"
PREFILTER_MARGIN_MS=4000
M3U_DIR=""
PLAYLIST_FILE=""
MISSING_POLICY="report"

DOWNLOADER_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --batch-root)
      [[ $# -ge 2 ]] || err "--batch-root requires a value"
      BATCH_ROOT="$2"
      shift 2
      ;;
    --source)
      [[ $# -ge 2 ]] || err "--source requires a value"
      SOURCE="$2"
      shift 2
      ;;
    --url)
      [[ $# -ge 2 ]] || err "--url requires a value"
      URL="$2"
      shift 2
      ;;
    --db)
      [[ $# -ge 2 ]] || err "--db requires a value"
      DB_PATH="$2"
      shift 2
      ;;
    --library-root)
      [[ $# -ge 2 ]] || err "--library-root requires a value"
      LIBRARY_ROOT="$2"
      shift 2
      ;;
    --fix-root)
      [[ $# -ge 2 ]] || err "--fix-root requires a value"
      FIX_ROOT="$2"
      shift 2
      ;;
    --out-dir)
      [[ $# -ge 2 ]] || err "--out-dir requires a value"
      OUT_DIR="$2"
      shift 2
      ;;
    --workers)
      [[ $# -ge 2 ]] || err "--workers requires a value"
      WORKERS="$2"
      shift 2
      ;;
    --trust)
      [[ $# -ge 2 ]] || err "--trust requires a value"
      TRUST="$2"
      shift 2
      ;;
    --trust-post)
      [[ $# -ge 2 ]] || err "--trust-post requires a value"
      TRUST_POST="$2"
      shift 2
      ;;
    --library-tag)
      [[ $# -ge 2 ]] || err "--library-tag requires a value"
      LIBRARY_TAG="$2"
      shift 2
      ;;
    --execute)
      EXECUTE=1
      shift
      ;;
    --m3u)
      M3U_MODE=1
      shift
      ;;
    --m3u-only)
      M3U_ONLY=1
      M3U_MODE=1
      shift
      ;;
    --m3u-dir)
      [[ $# -ge 2 ]] || err "--m3u-dir requires a value"
      M3U_DIR="$2"
      shift 2
      ;;
    --playlist-file)
      [[ $# -ge 2 ]] || err "--playlist-file requires a value"
      PLAYLIST_FILE="$2"
      shift 2
      ;;
    --missing-policy)
      [[ $# -ge 2 ]] || err "--missing-policy requires a value"
      MISSING_POLICY="$2"
      shift 2
      ;;
    --no-download)
      DOWNLOAD=0
      shift
      ;;
    --skip-mgmt-check)
      SKIP_MGMT_CHECK=1
      shift
      ;;
    --skip-beatport-prefilter)
      SKIP_BEATPORT_PREFILTER=1
      shift
      ;;
    --prefilter-margin-ms)
      [[ $# -ge 2 ]] || err "--prefilter-margin-ms requires a value"
      PREFILTER_MARGIN_MS="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      DOWNLOADER_ARGS+=("$@")
      break
      ;;
    -*)
      err "Unknown option: $1"
      ;;
    *)
      if [[ -z "$URL" ]]; then
        URL="$1"
      else
        DOWNLOADER_ARGS+=("$1")
      fi
      shift
      ;;
  esac
done

if [[ "$M3U_ONLY" -eq 0 && -n "$URL" && -z "$BATCH_ROOT" ]]; then
  M3U_ONLY=1
  M3U_MODE=1
  DOWNLOAD=0
  echo "Auto mode: no --batch-root provided; running in --m3u-only mode."
fi

if [[ -z "$DB_PATH" ]]; then
  DB_PATH="$(autodetect_db_path)"
fi
if [[ -z "$DB_PATH" ]]; then
  if [[ "${AUTO_DB_AMBIGUOUS:-0}" -eq 1 ]]; then
    echo "Multiple DB candidates found:" >&2
    printf '  - %s\n' "${AUTO_DB_CANDIDATES[@]}" >&2
    err "Set --db or TAGSLUT_DB to choose the correct DB."
  fi
  err "Missing DB path. Set --db or TAGSLUT_DB."
fi
[[ "$TRUST" =~ ^[0-3]$ ]] || err "--trust must be 0,1,2,3"
[[ "$TRUST_POST" =~ ^[0-3]$ ]] || err "--trust-post must be 0,1,2,3"
[[ "$WORKERS" =~ ^[0-9]+$ ]] || err "--workers must be an integer"
[[ "$PREFILTER_MARGIN_MS" =~ ^[0-9]+$ ]] || err "--prefilter-margin-ms must be an integer"
case "$MISSING_POLICY" in
  ask|report|skip|download) ;;
  *) err "--missing-policy must be one of: ask, report, skip, download" ;;
esac

if [[ "$M3U_ONLY" -eq 1 ]]; then
  if [[ -z "$URL" && -z "$PLAYLIST_FILE" ]]; then
    err "--m3u-only requires either URL or --playlist-file"
  fi
else
  [[ -n "$BATCH_ROOT" ]] || err "--batch-root is required"
  if [[ "$DOWNLOAD" -eq 1 && -z "$URL" ]]; then
    err "URL is required unless --no-download is used"
  fi
fi

if [[ -z "$SOURCE" && -n "$URL" ]]; then
  SOURCE="$(infer_source "$URL")"
fi
[[ -n "$SOURCE" ]] || SOURCE="ingest"

[[ -x "$GET_BIN" ]] || err "Missing executable: $GET_BIN"
[[ -x "$BPDL_BIN" ]] || err "Missing executable: $BPDL_BIN"
[[ -f "$SCAN_SCRIPT" ]] || err "Missing script: $SCAN_SCRIPT"
[[ -f "$AUDIT_SCRIPT" ]] || err "Missing script: $AUDIT_SCRIPT"
[[ -f "$PLAN_SCRIPT" ]] || err "Missing script: $PLAN_SCRIPT"
[[ -f "$MOVE_SCRIPT" ]] || err "Missing script: $MOVE_SCRIPT"
[[ -f "$BEATPORT_PREFILTER_SCRIPT" ]] || err "Missing script: $BEATPORT_PREFILTER_SCRIPT"

command -v poetry >/dev/null 2>&1 || err "poetry is required in PATH"
command -v python >/dev/null 2>&1 || err "python is required in PATH"

if [[ "$M3U_ONLY" -eq 0 ]]; then
  if [[ "$DOWNLOAD" -eq 1 ]]; then
    mkdir -p "$BATCH_ROOT"
  else
    [[ -d "$BATCH_ROOT" ]] || err "--batch-root does not exist: $BATCH_ROOT"
  fi
  BATCH_ROOT="$(cd "$BATCH_ROOT" && pwd -P)"
else
  BATCH_ROOT=""
fi

LIBRARY_ROOT="$(cd "$LIBRARY_ROOT" && pwd -P)"
FIX_ROOT="$(cd "$FIX_ROOT" && pwd -P)"
DB_PATH="$(cd "$(dirname "$DB_PATH")" && pwd -P)/$(basename "$DB_PATH")"
if [[ "$M3U_MODE" -eq 1 ]]; then
  if [[ -z "$M3U_DIR" ]]; then
    M3U_DIR="$LIBRARY_ROOT"
  fi
  mkdir -p "$M3U_DIR"
  M3U_DIR="$(cd "$M3U_DIR" && pwd -P)"
fi
mkdir -p "$OUT_DIR"
OUT_DIR="$(cd "$OUT_DIR" && pwd -P)"

echo "Batch root:   $BATCH_ROOT"
echo "Source:       $SOURCE"
echo "DB:           $DB_PATH"
echo "Library root: $LIBRARY_ROOT"
echo "FIX root:     $FIX_ROOT"
echo "Output dir:   $OUT_DIR"
echo "Execute:      $EXECUTE"
echo "Prefilter:    $((1 - SKIP_BEATPORT_PREFILTER))"
if [[ "$M3U_MODE" -eq 1 ]]; then
  echo "M3U:          1 (dir=$M3U_DIR)"
else
  echo "M3U:          0"
fi
if [[ "$M3U_ONLY" -eq 1 ]]; then
  echo "M3U only:     1"
  echo "Missing mode: $MISSING_POLICY"
fi

if [[ "$M3U_ONLY" -eq 1 ]]; then
  STEP=1
  TOTAL_STEPS=3
  M3U_NAME_HINT=""

  M3U_EXISTING_FILE="$OUT_DIR/m3u_existing_paths_$(date +%Y%m%d_%H%M%S).txt"
  M3U_MISSING_URLS_FILE="$OUT_DIR/m3u_missing_urls_$(date +%Y%m%d_%H%M%S).txt"
  M3U_MISSING_ITEMS_FILE="$OUT_DIR/m3u_missing_items_$(date +%Y%m%d_%H%M%S).txt"

  if [[ -n "$URL" ]]; then
    M3U_NAME_HINT="$(playlist_label_from_url "$URL")"
    step "$STEP" "$TOTAL_STEPS" "Resolve M3U candidates from URL"
    if [[ "$URL" != *"beatport.com"* ]]; then
      err "--m3u-only URL mode currently supports Beatport URLs. Use --playlist-file for other sources."
    fi

    run_cmd python "$BEATPORT_PREFILTER_SCRIPT" \
      --db "$DB_PATH" \
      --url "$URL" \
      --library-root "$LIBRARY_ROOT" \
      --credentials "$SCRIPT_DIR/beatportdl/bpdl/beatportdl-credentials.json" \
      --duration-margin-ms "$PREFILTER_MARGIN_MS" \
      --out-dir "$OUT_DIR"

    PREFILTER_SUMMARY_JSON="$(ls -1t "$OUT_DIR"/beatport_prefilter_summary_*.json 2>/dev/null | head -n1 || true)"
    [[ -n "$PREFILTER_SUMMARY_JSON" ]] || err "Could not find Beatport prefilter summary in $OUT_DIR"

    PREFILTER_DECISIONS_CSV="$(python - "$PREFILTER_SUMMARY_JSON" <<'PY'
import json
import sys
with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)
print(payload.get("outputs", {}).get("decisions_csv", ""))
PY
)"
    [[ -n "$PREFILTER_DECISIONS_CSV" ]] || err "Missing decisions_csv in prefilter summary: $PREFILTER_SUMMARY_JSON"

    FALLBACK_LOCAL_ROOTS=()
    BPDL_DOWNLOAD_ROOT="$(bpdl_downloads_dir_from_config)"
    if [[ -n "$BPDL_DOWNLOAD_ROOT" && -d "$BPDL_DOWNLOAD_ROOT" ]]; then
      FALLBACK_LOCAL_ROOTS+=("$BPDL_DOWNLOAD_ROOT")
    fi

    PREFILTER_RESOLVE_ARGS=(
      "$PREFILTER_DECISIONS_CSV"
      "$M3U_EXISTING_FILE"
      "$M3U_MISSING_URLS_FILE"
      "$M3U_MISSING_ITEMS_FILE"
    )
    if [[ ${#FALLBACK_LOCAL_ROOTS[@]} -gt 0 ]]; then
      PREFILTER_RESOLVE_ARGS+=("${FALLBACK_LOCAL_ROOTS[@]}")
    fi

    python - "${PREFILTER_RESOLVE_ARGS[@]}" <<'PY'
import csv
import re
import sys
from pathlib import Path

decisions_csv = Path(sys.argv[1])
existing_file = Path(sys.argv[2])
missing_urls_file = Path(sys.argv[3])
missing_items_file = Path(sys.argv[4])
fallback_roots = [Path(value).expanduser().resolve() for value in sys.argv[5:] if value.strip()]

existing = []
missing_urls = []
missing_items = []
seen_existing = set()
seen_urls = set()
seen_missing = set()
unresolved = []


def norm_text(value: str) -> str:
    text = (value or "").strip().lower()
    if not text:
        return ""
    text = re.sub(r"[^a-z0-9]+", " ", text)
    return re.sub(r"\s+", " ", text).strip()


def token_set(value: str) -> set[str]:
    return {token for token in norm_text(value).split() if len(token) >= 3}


def build_candidates(roots: list[Path]) -> list[tuple[str, set[str], str]]:
    candidates = []
    seen_paths = set()
    for root in roots:
        if not root.is_dir():
            continue
        for file_path in root.rglob("*.flac"):
            if file_path.name.startswith("._"):
                continue
            resolved = str(file_path.resolve())
            if resolved in seen_paths:
                continue
            seen_paths.add(resolved)
            name_norm = norm_text(file_path.stem)
            candidates.append((name_norm, set(name_norm.split()), resolved))
    return candidates


def match_unresolved(row: dict[str, str], candidates: list[tuple[str, set[str], str]]) -> str:
    title = (row.get("title") or "").strip()
    mix_name = (row.get("mix_name") or "").strip()
    artist = (row.get("artist") or "").strip()

    title_norm = norm_text(title)
    mix_norm = norm_text(mix_name)
    artist_tokens = token_set(artist)
    title_tokens = token_set(title)
    mix_is_generic = mix_norm in {"", "original", "original mix", "extended", "extended mix"}

    for file_norm, file_tokens, file_path in candidates:
        if title_norm:
            if title_norm not in file_norm and not title_tokens.issubset(file_tokens):
                continue
        if mix_norm and not mix_is_generic and mix_norm not in file_norm:
            continue
        if artist_tokens and not (artist_tokens & file_tokens):
            continue
        return file_path
    return ""

with decisions_csv.open(newline="", encoding="utf-8") as handle:
    reader = csv.DictReader(handle)
    for row in reader:
        action = (row.get("action") or "").strip().lower()
        matched_path = (row.get("matched_path") or "").strip()
        candidate_url = (row.get("url") or "").strip()
        artist = (row.get("artist") or "").strip()
        title = (row.get("title") or "").strip()

        if matched_path:
            path_obj = Path(matched_path).expanduser()
            if path_obj.exists() and path_obj.suffix.lower() == ".flac":
                resolved = str(path_obj.resolve())
                if resolved not in seen_existing:
                    seen_existing.add(resolved)
                    existing.append(resolved)
                continue

        if action == "keep" and candidate_url:
            unresolved.append(
                {
                    "url": candidate_url,
                    "artist": artist,
                    "title": title,
                    "mix_name": (row.get("mix_name") or "").strip(),
                }
            )

if fallback_roots and unresolved:
    candidates = build_candidates(fallback_roots)
    still_unresolved = []
    for row in unresolved:
        matched = match_unresolved(row, candidates)
        if matched:
            if matched not in seen_existing:
                seen_existing.add(matched)
                existing.append(matched)
            continue
        still_unresolved.append(row)
    unresolved = still_unresolved

for row in unresolved:
    candidate_url = row["url"]
    artist = row["artist"]
    title = row["title"]
    if candidate_url not in seen_urls:
        seen_urls.add(candidate_url)
        missing_urls.append(candidate_url)
    label = f"{artist} - {title}".strip(" -")
    if label and label not in seen_missing:
        seen_missing.add(label)
        missing_items.append(label)

for path in (existing_file, missing_urls_file, missing_items_file):
    path.parent.mkdir(parents=True, exist_ok=True)

existing_file.write_text("\n".join(existing) + ("\n" if existing else ""), encoding="utf-8")
