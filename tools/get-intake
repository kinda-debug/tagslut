        missing_urls.append(candidate_url)
    label = f"{artist} - {title}".strip(" -")
    if label and label not in seen_missing:
        seen_missing.add(label)
        missing_items.append(label)

for path in (existing_file, missing_urls_file, missing_items_file):
    path.parent.mkdir(parents=True, exist_ok=True)

existing_file.write_text("\n".join(existing) + ("\n" if existing else ""), encoding="utf-8")
