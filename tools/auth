#!/usr/bin/env bash
# auth — Refresh all provider tokens and sync to downstream tools.
#
# Usage:
#   tools/auth           # refresh all (tidal, beatport, qobuz)
#   tools/auth tidal     # refresh TIDAL only
#   tools/auth beatport  # refresh Beatport only
#   tools/auth qobuz     # refresh Qobuz app credentials + sync to streamrip

set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_wrapper_common.sh"
ts_wrapper_bootstrap "${BASH_SOURCE[0]}"
PYTHON_BIN="$(ts_repo_python)"
export PATH="$HOME/.local/bin:$PATH"

cd "$TAGSLUT_REPO_ROOT"

PROVIDER="${1:-all}"

STREAMRIP_CONFIG="${STREAMRIP_CONFIG:-$HOME/Library/Application Support/streamrip/config.toml}"
TOKENS_FILE="$HOME/.config/tagslut/tokens.json"

resolve_beatportdl_creds() {
    local candidate=""
    local cmd_override="${BEATPORTDL_BIN:-${BEATPORTDL_CMD:-}}"
    local helper_path="${TAGSLUT_TOOLS_DIR}/_beatportdl.sh"

    if [[ -n "${BEATPORTDL_CREDS:-}" && -f "${BEATPORTDL_CREDS}" ]]; then
        printf '%s\n' "${BEATPORTDL_CREDS}"
        return 0
    fi

    if [[ -n "$cmd_override" && "$cmd_override" != "$helper_path" ]]; then
        candidate="$(dirname "$cmd_override")/beatportdl-credentials.json"
        if [[ -f "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    fi

    for candidate in \
        "${TAGSLUT_TOOLS_DIR}/beatportdl/bpdl/beatportdl-credentials.json" \
        "$HOME/Projects/beatportdl/beatportdl-credentials.json"; do
        if [[ -f "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

sync_qobuz_tokens() {
    # One-way: push tagslut tokens.json + preferred Qobuz settings → streamrip config.toml
    # tagslut is the authoritative source; never pull from streamrip
    [[ -f "$STREAMRIP_CONFIG" ]] || return 0
    [[ -f "$TOKENS_FILE" ]] || return 0
    "$PYTHON_BIN" - "$STREAMRIP_CONFIG" "$TOKENS_FILE" << 'PYEOF'
import json, re, sys
from pathlib import Path

cfg_path, tok_path = sys.argv[1], sys.argv[2]
tokens = json.loads(Path(tok_path).read_text())
q = tokens.get("qobuz", {})
user_token = q.get("user_auth_token", "")
user_id = q.get("user_id", "")
if not (user_token and user_id):
    sys.exit(0)
cfg_text = Path(cfg_path).read_text(encoding="utf-8")

def upsert_key(text: str, section: str, key: str, raw_value: str) -> str:
    section_re = re.compile(rf"(?ms)^\[{re.escape(section)}\]\s*\n.*?(?=^\[|\Z)")
    key_re = re.compile(rf"(?m)^\s*{re.escape(key)}\s*=.*$")
    line = f"{key} = {raw_value}"
    match = section_re.search(text)
    if match:
        block = match.group(0)
        if key_re.search(block):
            updated = key_re.sub(line, block, count=1)
        else:
            suffix = "" if block.endswith("\n") else "\n"
            updated = f"{block}{suffix}{line}\n"
        return text[:match.start()] + updated + text[match.end():]

    prefix = "" if not text.strip() else text.rstrip("\n") + "\n\n"
    return f"{prefix}[{section}]\n{line}\n"

def toml_string(value: str) -> str:
    return json.dumps(value)

updates = [
    ("qobuz", "use_auth_token", "true"),
    ("qobuz", "email_or_userid", toml_string(str(user_id))),
    ("qobuz", "password_or_token", toml_string(str(user_token))),
    ("qobuz", "quality", "4"),
    ("qobuz", "download_booklets", "true"),
    ("artwork", "embed", "true"),
    ("artwork", "size", toml_string("original")),
    ("artwork", "embed_size", toml_string("original")),
    ("artwork", "keep_hires_cover", "true"),
    ("artwork", "save_artwork", "true"),
    ("artwork", "max_width", "-1"),
    ("artwork", "max_height", "-1"),
    ("artwork", "embed_max_width", "-1"),
    ("artwork", "saved_max_width", "-1"),
    ("metadata", "exclude", "[]"),
    ("metadata", "set_playlist_to_album", "true"),
    (
        "filepaths",
        "folder_format",
        toml_string("{albumartist} - {title} ({year}) [{container}] [{bit_depth}B-{sampling_rate}kHz]"),
    ),
    (
        "filepaths",
        "track_format",
        toml_string("{tracknumber:02}. {artist} - {title}{explicit}"),
    ),
]

for section, key, raw_value in updates:
    cfg_text = upsert_key(cfg_text, section, key, raw_value)

Path(cfg_path).write_text(cfg_text)
PYEOF
}

# Keep old name as alias for compatibility
sync_qobuz_to_streamrip() { sync_qobuz_tokens; }

refresh_tidal() {
    echo -n "TIDAL... "
    "$TAGSLUT_TOOLS_DIR/tiddl" auth refresh 2>/dev/null && echo "OK" || echo "FAILED"
}

BEATPORTDL_CREDS="$(resolve_beatportdl_creds || true)"

sync_beatport_from_beatportdl() {
    [[ -n "$BEATPORTDL_CREDS" && -f "$BEATPORTDL_CREDS" ]] || return 1
    "$PYTHON_BIN" - "$BEATPORTDL_CREDS" << 'PYEOF'
import json, sys, time, urllib.request, urllib.parse
from pathlib import Path

creds_path = sys.argv[1]
creds = json.load(open(creds_path))

CLIENT_ID = "ryZ8LuyQVPqbK2mBX2Hwt4qSMtnWuTYSqBPO92yQ"
refresh_token = creds.get("refresh_token", "")
issued_at = int(creds.get("issued_at", 0))
expires_in = int(creds.get("expires_in", 36000))
is_expired = (issued_at + expires_in) < time.time()

# Attempt refresh if token is expired or expiring within 30 minutes
if is_expired or (issued_at + expires_in - time.time()) < 1800:
    try:
        data = urllib.parse.urlencode({
            "client_id": CLIENT_ID,
            "grant_type": "refresh_token",
            "refresh_token": refresh_token,
        }).encode()
        req = urllib.request.Request(
            "https://api.beatport.com/v4/auth/o/token/",
            data=data,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )
        with urllib.request.urlopen(req, timeout=15) as resp:
            new_tokens = json.loads(resp.read())
        creds["access_token"] = new_tokens["access_token"]
        creds["refresh_token"] = new_tokens.get("refresh_token", refresh_token)
        creds["expires_in"] = new_tokens.get("expires_in", 36000)
        creds["issued_at"] = int(time.time())
        open(creds_path, "w").write(json.dumps(creds, indent=1))
    except Exception as e:
        # Refresh failed — proceed with existing token, warn
        sys.stderr.write(f"Beatport token refresh failed: {e}\n")

# Sync into tokens.json regardless
tokens_path = Path.home() / ".config/tagslut/tokens.json"
tokens = json.loads(tokens_path.read_text()) if tokens_path.exists() else {}
if "beatport" not in tokens or not isinstance(tokens.get("beatport"), dict):
    tokens["beatport"] = {}
expires_at = int(creds.get("issued_at", 0)) + int(creds.get("expires_in", 36000))
tokens["beatport"]["access_token"] = creds["access_token"]
tokens["beatport"]["refresh_token"] = creds["refresh_token"]
tokens["beatport"]["expires_at"] = expires_at
tokens["beatport"]["client_id"] = CLIENT_ID
tokens_path.write_text(json.dumps(tokens, indent=2))
PYEOF
}

refresh_beatport() {
    echo -n "Beatport... "
    if sync_beatport_from_beatportdl; then
        echo "OK (synced from beatportdl)"
    else
        "$TAGSLUT_TOOLS_DIR/tagslut" auth refresh beatport 2>/dev/null && echo "OK" || echo "FAILED"
    fi
}

refresh_qobuz() {
    echo -n "Qobuz... "
    # Refresh app credentials (app_id/app_secret) — never overwrites user_auth_token
    "$TAGSLUT_TOOLS_DIR/tagslut" auth refresh qobuz 2>/dev/null
    # Push current tokens.json → streamrip (one-way; tagslut is authoritative)
    sync_qobuz_tokens
    # Verify session is actually valid
    local valid
    valid=$("$PYTHON_BIN" -c "
import sys, json, requests
from pathlib import Path
try:
    tokens = json.loads((Path.home() / '.config/tagslut/tokens.json').read_text())
    q = tokens.get('qobuz', {})
    app_id = q.get('app_id', '')
    tok = q.get('user_auth_token', '')
    user_id = q.get('user_id', '')
    if not (app_id and tok):
        print('0'); sys.exit(0)
    r = requests.get(
        'https://www.qobuz.com/api.json/0.2/user/get',
        params={'app_id': app_id, 'user_id': user_id},
        headers={'X-App-Id': app_id, 'X-User-Auth-Token': tok},
        timeout=8,
    )
    print('1' if r.status_code == 200 else '0')
except Exception:
    print('0')
" 2>/dev/null)
    if [[ "$valid" == "1" ]]; then
        echo "OK"
    else
        echo "session expired — re-login required:"
        echo "  poetry run tagslut auth login qobuz --email YOUR_EMAIL --force"
    fi
}

case "$PROVIDER" in
    all)
        refresh_tidal
        refresh_beatport
        refresh_qobuz
        ;;
    tidal)    refresh_tidal ;;
    beatport) refresh_beatport ;;
    qobuz)    refresh_qobuz ;;
    *)
        echo "Unknown provider: $PROVIDER" >&2
        echo "Usage: tools/auth [all|tidal|beatport|qobuz]" >&2
        exit 1
        ;;
esac
