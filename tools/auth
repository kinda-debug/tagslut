#!/usr/bin/env bash
# auth — Refresh all provider tokens and sync to downstream tools.
#
# Usage:
#   tools/auth           # refresh all (tidal, beatport, qobuz)
#   tools/auth tidal     # refresh TIDAL only
#   tools/auth beatport  # refresh Beatport only
#   tools/auth qobuz     # refresh Qobuz app credentials + sync to streamrip

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_LOADER="$SCRIPT_DIR/_load_env.sh"
export PATH="$HOME/.local/bin:$PATH"

if [[ -f "$ENV_LOADER" ]]; then
    source "$ENV_LOADER" 2>/dev/null
    load_workspace_env "$REPO_ROOT" 2>/dev/null
fi

cd "$REPO_ROOT"

PROVIDER="${1:-all}"

STREAMRIP_CONFIG="/Users/georgeskhawam/Projects/streamrip/dev_config.toml"
TOKENS_FILE="$HOME/.config/tagslut/tokens.json"

sync_qobuz_tokens() {
    # Bidirectional: whichever side has a valid token wins.
    # If streamrip config has a token that tagslut doesn't (or tagslut's is older), pull from streamrip.
    # Then always write tagslut's current token back to streamrip so both stay in sync.
    [[ -f "$STREAMRIP_CONFIG" ]] || return 0
    [[ -f "$TOKENS_FILE" ]] || return 0
    python3 - "$STREAMRIP_CONFIG" "$TOKENS_FILE" << 'PYEOF'
import json, re, sys
from pathlib import Path

cfg_path, tok_path = sys.argv[1], sys.argv[2]
tokens = json.loads(Path(tok_path).read_text())
q = tokens.get("qobuz", {})

import tomllib
cfg_text = Path(cfg_path).read_text()
cfg_data = tomllib.loads(cfg_text)
sr_qobuz = cfg_data.get("qobuz", {})

# Pull from streamrip if tagslut token is missing/expired
sr_token = str(sr_qobuz.get("password_or_token", ""))
sr_user_id = str(sr_qobuz.get("email_or_userid", ""))
tagslut_token = q.get("user_auth_token", "")

if sr_token and sr_token != tagslut_token and len(sr_token) > 20:
    q["user_auth_token"] = sr_token
    if sr_user_id and sr_user_id.isdigit():
        q["user_id"] = sr_user_id
    tokens["qobuz"] = q
    Path(tok_path).write_text(json.dumps(tokens, indent=2))

# Write current (possibly just-updated) token back to streamrip
user_token = q.get("user_auth_token", "")
user_id = q.get("user_id", "")
if not (user_token and user_id):
    sys.exit(0)
cfg_text = re.sub(r'use_auth_token = \w+', 'use_auth_token = true', cfg_text)
cfg_text = re.sub(r'email_or_userid = ".*?"', f'email_or_userid = "{user_id}"', cfg_text)
cfg_text = re.sub(r'password_or_token = ".*?"', f'password_or_token = "{user_token}"', cfg_text)
Path(cfg_path).write_text(cfg_text)
PYEOF
}

# Keep old name as alias for compatibility
sync_qobuz_to_streamrip() { sync_qobuz_tokens; }

refresh_tidal() {
    echo -n "TIDAL... "
    tiddl auth refresh 2>/dev/null && echo "OK" || echo "FAILED"
}

BEATPORTDL_CREDS="$HOME/Projects/beatportdl/beatportdl-credentials.json"

sync_beatport_from_beatportdl() {
    [[ -f "$BEATPORTDL_CREDS" ]] || return 1
    python3 - "$BEATPORTDL_CREDS" << 'PYEOF'
import json, sys, time, urllib.request, urllib.parse
from pathlib import Path

creds_path = sys.argv[1]
creds = json.load(open(creds_path))

CLIENT_ID = "ryZ8LuyQVPqbK2mBX2Hwt4qSMtnWuTYSqBPO92yQ"
refresh_token = creds.get("refresh_token", "")
issued_at = int(creds.get("issued_at", 0))
expires_in = int(creds.get("expires_in", 36000))
is_expired = (issued_at + expires_in) < time.time()

# Attempt refresh if token is expired or expiring within 30 minutes
if is_expired or (issued_at + expires_in - time.time()) < 1800:
    try:
        data = urllib.parse.urlencode({
            "client_id": CLIENT_ID,
            "grant_type": "refresh_token",
            "refresh_token": refresh_token,
        }).encode()
        req = urllib.request.Request(
            "https://api.beatport.com/v4/auth/o/token/",
            data=data,
            headers={"Content-Type": "application/x-www-form-urlencoded"},
        )
        with urllib.request.urlopen(req, timeout=15) as resp:
            new_tokens = json.loads(resp.read())
        creds["access_token"] = new_tokens["access_token"]
        creds["refresh_token"] = new_tokens.get("refresh_token", refresh_token)
        creds["expires_in"] = new_tokens.get("expires_in", 36000)
        creds["issued_at"] = int(time.time())
        open(creds_path, "w").write(json.dumps(creds, indent=1))
    except Exception as e:
        # Refresh failed — proceed with existing token, warn
        sys.stderr.write(f"Beatport token refresh failed: {e}\n")

# Sync into tokens.json regardless
tokens_path = Path.home() / ".config/tagslut/tokens.json"
tokens = json.loads(tokens_path.read_text()) if tokens_path.exists() else {}
if "beatport" not in tokens or not isinstance(tokens.get("beatport"), dict):
    tokens["beatport"] = {}
expires_at = int(creds.get("issued_at", 0)) + int(creds.get("expires_in", 36000))
tokens["beatport"]["access_token"] = creds["access_token"]
tokens["beatport"]["refresh_token"] = creds["refresh_token"]
tokens["beatport"]["expires_at"] = expires_at
tokens["beatport"]["client_id"] = CLIENT_ID
tokens_path.write_text(json.dumps(tokens, indent=2))
PYEOF
}

refresh_beatport() {
    echo -n "Beatport... "
    if sync_beatport_from_beatportdl; then
        echo "OK (synced from beatportdl)"
    else
        poetry run python -m tagslut auth refresh beatport 2>/dev/null && echo "OK" || echo "FAILED"
    fi
}

refresh_qobuz() {
    echo -n "Qobuz... "
    poetry run python -m tagslut auth refresh qobuz 2>/dev/null \
        && sync_qobuz_to_streamrip \
        && echo "OK" \
        || echo "FAILED"
}

case "$PROVIDER" in
    all)
        refresh_tidal
        refresh_beatport
        refresh_qobuz
        ;;
    tidal)    refresh_tidal ;;
    beatport) refresh_beatport ;;
    qobuz)    refresh_qobuz ;;
    *)
        echo "Unknown provider: $PROVIDER" >&2
        echo "Usage: tools/auth [all|tidal|beatport|qobuz]" >&2
        exit 1
        ;;
esac
