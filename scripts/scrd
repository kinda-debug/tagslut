#!/bin/bash
# ScaReD - Super Concise Runner for Easy Deduplication
# Usage: scrd [command] [options]
#
# Commands:
#   sc, scan     - Scan FLAC library
#   r, repair    - Repair broken files
#   d, dedupe    - Find/remove duplicates
#   wf, workflow - Run complete workflow (default)
#   st, status   - Show current status
#   cl, clean    - Clean up temporary files
#   h, help      - Show this help

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Config file location
CONFIG_FILE="config.toml"

# Check if poetry is available (but prefer direct Python execution since it works better)
POETRY_CMD=""
# Always use direct Python execution for reliability
echo -e "${BLUE}Using direct Python execution (bypassing Poetry for reliability)${NC}"

# Function to get config value
get_config() {
    local section=$1
    local key=$2
    local default=$3

    if [ -f "$CONFIG_FILE" ]; then
        # Use Python to parse TOML config
        python3 -c "
import tomllib
try:
    with open('$CONFIG_FILE', 'rb') as f:
        config = tomllib.load(f)
    value = config.get('$section', {}).get('$key', '$default')
    print(value)
except:
    print('$default')
" 2>/dev/null || echo "$default"
    else
        echo "$default"
    fi
}

# Function to run poetry commands with config
run_poetry() {
    local cmd=$1
    shift

    # Add root directory from config if not specified
    if [[ "$cmd" != "status" && "$cmd" != "clean" ]] && [[ "$@" != *"--root"* ]]; then
        local root=$(get_config "paths" "root" "/Volumes/dotad/MUSIC")
        echo -e "${BLUE}Using root directory: $root${NC}"
        set -- "--root" "$root" "$@"
    fi

    if [ -n "$POETRY_CMD" ]; then
        echo -e "${BLUE}Running: $POETRY_CMD run dedupe $cmd $@${NC}"
        $POETRY_CMD run dedupe "$cmd" "$@"
    else
        echo -e "${BLUE}Running: python3 dedupe_cli.py $cmd $@${NC}"
        python3 dedupe_cli.py "$cmd" "$@"
    fi
}

# Function to show help
show_help() {
    cat << EOF
${GREEN}ScaReD - Super Concise Runner for Easy Deduplication${NC}

${YELLOW}Usage:${NC}
  scrd [command] [options]

${YELLOW}Commands:${NC}
  sc, scan      Scan FLAC library and build database
  r, repair     Repair broken/corrupt FLAC files
  d, dedupe     Find and remove duplicate files
  wf, workflow  Run complete scan→repair→dedupe workflow (default)
  st, status    Show current deduplication status
  cl, clean     Clean up temporary files and cache
  h, help       Show this help message

${YELLOW}Configuration:${NC}
  Settings are loaded from ${BLUE}config.toml${NC}
  Edit this file to customize default behavior

${YELLOW}Examples:${NC}
  scrd sc --verbose          # Scan with verbose output
  scrd r                     # Repair broken files
  scrd d --commit            # Remove duplicates
  scrd wf --commit           # Run full workflow
  scrd st                    # Show status
  scrd cl                    # Clean up

${YELLOW}All options are passed through to the underlying commands.${NC}
EOF
}

# Main command processing
echo -e "${BLUE}ScaReD: Processing command '${1:-wf}'${NC}"
case "${1:-wf}" in
    sc|scan)
        shift
        run_poetry scan "$@"
        ;;
    r|repair)
        shift
        run_poetry repair "$@"
        ;;
    d|dedupe)
        shift
        run_poetry dedupe "$@"
        ;;
    wf|workflow)
        shift
        run_poetry workflow "$@"
        ;;
    st|status)
        shift
        run_poetry status "$@"
        ;;
    cl|clean)
        shift
        run_poetry clean "$@"
        ;;
    h|help|--help|-h)
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        show_help
        exit 1
        ;;
esac