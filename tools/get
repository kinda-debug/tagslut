#!/usr/bin/env bash
# get — Unified intake/download entrypoint for Tidal, Beatport, and Deezer URLs
#
# Routes URLs to the appropriate workflow based on domain:
#   - tidal.com    → tools/get-intake sync flow (or tools/tiddl for --simple)
#   - beatport.com → tools/get-intake sync flow (or bpdl for --simple)
#   - deezer.com   → tools/deemix (Deezer wrapper + auto-register)
#
# Usage:
#   tools/get [--sync|--synch|--simple] <url> [extra-args...]
#
# Examples:
#   tools/get https://tidal.com/browse/playlist/12345
#   tools/get https://www.beatport.com/release/some-release/12345
#   tools/get https://listen.tidal.com/album/12345 --quality high
#
# After downloading, register to inventory and generate M3U:
#   tagslut index register <download-path> --source <tidal|bpdl>
#   tagslut report m3u <download-path>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TIDDL_WRAPPER="$SCRIPT_DIR/tiddl"
DEEMIX_WRAPPER="$SCRIPT_DIR/deemix"
BPDL_BIN="$SCRIPT_DIR/beatportdl/bpdl/bpdl"
GET_INTAKE="$SCRIPT_DIR/get-intake"
GET_REPORT="$SCRIPT_DIR/get-report"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_LOADER="$SCRIPT_DIR/_load_env.sh"

if [[ -f "$ENV_LOADER" ]]; then
    # Load repo-local .env so wrapper commands see TAGSLUT_DB and volume roots.
    # shellcheck disable=SC1090
    source "$ENV_LOADER"
    load_workspace_env "$REPO_ROOT"
fi

usage() {
    echo "Primary workflow:"
    echo "  tools/get <provider-url>         precheck + download + local tag prep + promote + m3u"
    echo ""
    echo "General usage: tools/get [--sync|--synch|--simple] <url> [extra-args...]"
    echo "  --sync/--synch: provider sync workflow"
    echo "  --simple: downloader-only behavior"
    echo ""
    echo "Common high-level options:"
    echo "  --dj                 [LEGACY] deprecated — use the 4-stage pipeline instead"
    echo "                       See docs/DJ_WORKFLOW.md or: tagslut dj --help"
    echo "  --hoard              local tag prep before promote; enrich/art continue in background after promote (default)"
    echo "  --no-hoard           skip local tag prep and background enrich/art"
    echo "  --no-precheck        skip duplicate-quality precheck"
    echo "  --force-download     keep matched tracks anyway"
    echo "  --providers LIST     metadata providers for enrich step"
    echo "  --verbose            show internal paths, logs, and batch snapshots"
    echo ""
    echo "Routing roots:"
    echo "  fix         salvageable metadata/tag issues (default: \$FIX_ROOT)"
    echo "  quarantine  risky files only (default: \$QUARANTINE_ROOT / \$VOLUME_QUARANTINE)"
    echo "  discard     deterministic duplicates like dest_exists (default: \$DISCARD_ROOT)"
    echo ""
    echo "Beatport-specific:"
    echo "  tools/get-report <beatport-url>  report only, no download"
    echo "  tools/get-sync <beatport-url>    deprecated compatibility alias"
    echo "Use tools/get-help for the tiny version of this help."
    exit 1
}

if [[ $# -lt 1 ]]; then
    usage
fi

MODE="auto"
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    usage
elif [[ "$1" == "--sync" || "$1" == "--synch" ]]; then
    MODE="sync"
    shift
elif [[ "$1" == "--simple" ]]; then
    MODE="simple"
    shift
fi

if [[ $# -lt 1 ]]; then
    usage
fi

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    usage
fi

URL="$1"
shift

INTAKE_CMD=()

build_intake_cmd() {
    local source="$1"
    local url="$2"
    shift 2

    local precheck_enabled=1
    local intake_args=()
    local arg=""
    while [[ $# -gt 0 ]]; do
        arg="$1"
        case "$arg" in
            --missing-only)
                shift
                ;;
            --allow-duplicates)
                precheck_enabled=0
                shift
                ;;
            --hoard)
                # Tagging/enrich/art pipeline is already the default intake behavior.
                shift
                ;;
            --no-hoard)
                intake_args+=(--no-tagging)
                shift
                ;;
            --dj)
                echo "[LEGACY] WARNING: tools/get --dj is deprecated." >&2
                echo "  The --dj flag has two divergent code paths and may produce non-deterministic results." >&2
                echo "  For a curated DJ library, use the explicit 4-stage pipeline:" >&2
                echo "    tagslut mp3 reconcile  --db \$TAGSLUT_DB --mp3-root \$DJ_LIBRARY --execute" >&2
                echo "    tagslut dj backfill    --db \$TAGSLUT_DB" >&2
                echo "    tagslut dj validate    --db \$TAGSLUT_DB" >&2
                echo "    tagslut dj xml emit    --db \$TAGSLUT_DB --out rekordbox.xml" >&2
                echo "  See: docs/DJ_WORKFLOW.md" >&2
                intake_args+=("$arg")
                shift
                ;;
            *)
                intake_args+=("$arg")
                shift
                ;;
        esac
    done

    INTAKE_CMD=("$GET_INTAKE" --source "$source" --missing-policy download --execute --m3u)
    if [[ "$precheck_enabled" -eq 0 ]]; then
        INTAKE_CMD+=(--no-precheck)
    fi
    INTAKE_CMD+=("$url")
    if [[ ${#intake_args[@]} -gt 0 ]]; then
        INTAKE_CMD+=("${intake_args[@]}")
    fi
}

# Route based on domain
if [[ "$URL" == *"tidal.com"* ]]; then
    if [[ ! -x "$GET_INTAKE" ]]; then
        echo "Error: get-intake not found or not executable at: $GET_INTAKE" >&2
        exit 1
    fi
    cd "$REPO_ROOT"
    if [[ "$MODE" == "simple" ]]; then
        exec "$TIDDL_WRAPPER" "$URL" "$@"
    fi
    build_intake_cmd "tidal" "$URL" "$@"
    exec "${INTAKE_CMD[@]}"

elif [[ "$URL" == *"beatport.com"* ]]; then
    if [[ ! -x "$GET_INTAKE" ]]; then
        echo "Error: get-intake not found or not executable at: $GET_INTAKE" >&2
        exit 1
    fi
    cd "$REPO_ROOT"
    if [[ "$MODE" == "simple" ]]; then
        if [[ ! -x "$BPDL_BIN" ]]; then
            echo "Error: BeatportDL binary not found or not executable at: $BPDL_BIN" >&2
            exit 1
        fi
        exec "$BPDL_BIN" "$URL" "$@"
    fi

    if [[ $# -eq 0 ]]; then
        exec "$GET_INTAKE" --source bpdl --missing-policy download --execute --m3u "$URL"
    fi

    if [[ "$1" == "--report" ]]; then
        shift
        if [[ ! -x "$GET_REPORT" ]]; then
            echo "Error: get-report not found or not executable at: $GET_REPORT" >&2
            exit 1
        fi
        exec "$GET_REPORT" "$URL" "$@"
    fi

    if [[ "$1" == "--raw-bpdl" ]]; then
        shift
        if [[ ! -x "$BPDL_BIN" ]]; then
            echo "Error: BeatportDL binary not found or not executable at: $BPDL_BIN" >&2
            exit 1
        fi
        exec "$BPDL_BIN" "$URL" "$@"
    fi

    build_intake_cmd "bpdl" "$URL" "$@"
    exec "${INTAKE_CMD[@]}"

elif [[ "$URL" == *"deezer.com"* || "$URL" == *"dzr.page.link"* ]]; then
    if [[ ! -x "$DEEMIX_WRAPPER" ]]; then
        echo "Error: deemix wrapper not found or not executable at: $DEEMIX_WRAPPER" >&2
        exit 1
    fi
    cd "$REPO_ROOT"
    exec "$DEEMIX_WRAPPER" "$URL" "$@"

else
    echo "Error: Unrecognized URL domain: $URL" >&2
    echo "Supported domains: tidal.com, beatport.com, deezer.com" >&2
    exit 1
fi
