-    max_windows = 3
-    step = step or (window - 10 if window > 10 else window)
-    windows = 0
-
-    while offset < duration and windows < max_windows:
-        with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as tmp:
-            tmp_path = Path(tmp.name)
-        try:
-            cmd = [
-                ffmpeg,
-                "-nostdin",
-                "-v",
-                "error",
-                "-ss",
-                str(offset),
-                "-t",
-                str(window),
-                "-i",
-                str(path),
-                "-f",
-                "wav",
-                str(tmp_path),
-            ]
-            try:
-                subprocess.run(
