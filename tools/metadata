#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BASE="$SCRIPT_DIR/metadata_scripts"
PY="$BASE/onetagger_workflow.py"
AUDIT="$BASE/metadata_audit.py"
NORM="$BASE/normalize_genres.py"
TAGNORM="$BASE/tag_normalized_genres.py"
TAGVALS="$BASE/tag_values_audit.py"
LEX="$BASE/lexicon_export.py"
LEXCMP="$BASE/lexicon_compare.py"
SYNC="$BASE/sync_tags_from_files.py"

cmd="${1:-}"
if [[ -z "$cmd" ]]; then
  echo "Usage: tools/metadata <full|tag|audiofeatures|audit|metadata|normalize-genres|tag-genres|audit-tags|export-lexicon|compare-lexicon> [args...]"
  exit 1
fi
shift

case "$cmd" in
  full)
    python "$PY" sync --metadata-after-isrc "$@"
    LIB_ROOT="${LIBRARY_ROOT:-/Volumes/MUSIC/LIBRARY}"
    python "$PY" audiofeatures --path "$LIB_ROOT"
    ;;
  tag)
    exec python "$PY" sync --metadata-after-isrc "$@"
    ;;
  audiofeatures)
    exec python "$PY" audiofeatures "$@"
    ;;
  metadata)
    exec python "$PY" metadata "$@"
    ;;
  audit)
    exec python "$AUDIT" "$@"
    ;;
  normalize-genres)
    exec python "$NORM" "$@"
    ;;
  tag-genres)
    exec python "$TAGNORM" "$@"
    ;;
  audit-tags)
    exec python "$TAGVALS" "$@"
    ;;
  export-lexicon)
    exec python "$LEX" "$@"
    ;;
  compare-lexicon)
    exec python "$LEXCMP" "$@"
    ;;
  sync-tags)
    exec python "$SYNC" "$@"
    ;;
  *)
    echo "Unknown command: $cmd"
    exit 1
    ;;
esac
