# Dedupe Environment Configuration
# Copy this file to .env and customize for your system

# ============================================================================
# DATABASE (source of truth)
# ============================================================================
# `DEDUPE_DB` is the canonical database path. Export this from your `.env`
# before running `dedupe` (or add it to your shell profile).
DEDUPE_DB=/Users/georgeskhawam/Projects/dedupe_db/EPOCH_20260119/music.db

# ============================================================================
# VOLUMES (physical locations - zones assigned per-file, not per-volume)
# ============================================================================
# Your volumes contain mixed content (dupes, unique, corrupt)
# Zones are determined by scan results, not volume location

# Primary library volume
VOLUME_LIBRARY=/Volumes/COMMUNE/M/Library

# Staging area
VOLUME_STAGING=/Volumes/COMMUNE/M/_staging

# Additional volumes with mixed content
VOLUME_VAULT=/Volumes/Vault/Vault
VOLUME_RECOVERY=/Volumes/RECOVERY_TARGET/Root/FINAL_LIBRARY

# Quarantine location
VOLUME_QUARANTINE=/Volumes/COMMUNE/M/_quarantine

# ============================================================================
# ARTIFACTS & LOGS
# ============================================================================
DEDUPE_ARTIFACTS=/Users/georgeskhawam/Projects/dedupe/artifacts
DEDUPE_REPORTS=/Users/georgeskhawam/Projects/dedupe/artifacts/M/03_reports

# ============================================================================
# SCAN SETTINGS
# ============================================================================
SCAN_WORKERS=8
SCAN_PROGRESS_INTERVAL=100
SCAN_CHECK_INTEGRITY=true
SCAN_CHECK_HASH=true
SCAN_INCREMENTAL=true

# ============================================================================
# DECISION SETTINGS
# ============================================================================
# Auto-approve high-confidence decisions
AUTO_APPROVE_THRESHOLD=0.95

# Quarantine retention (days before eligible for deletion)
QUARANTINE_RETENTION_DAYS=30

# Quality preferences
PREFER_HIGH_BITRATE=true
PREFER_HIGH_SAMPLE_RATE=true
PREFER_VALID_INTEGRITY=true
