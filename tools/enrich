#!/usr/bin/env bash
# enrich — Run metadata hoarding enrichment against the active DB.
#
# Usage:
#   tools/enrich              # enrich all unenriched/unmatched tracks (verbose by default)
#   tools/enrich --force      # re-enrich everything
#   tools/enrich --limit N    # cap at N tracks
#
# Reads TAGSLUT_DB from environment (set by env_exports.sh).
# Providers: beatport → tidal → qobuz (in priority order).
# All provider tokens are refreshed automatically before each run.

set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_wrapper_common.sh"
ts_wrapper_bootstrap "${BASH_SOURCE[0]}"

if [[ -z "${TAGSLUT_DB:-}" ]]; then
    echo "Error: TAGSLUT_DB is not set. Run: source env_exports.sh" >&2
    exit 1
fi

if [[ ! -f "$TAGSLUT_DB" ]]; then
    echo "Error: DB not found: $TAGSLUT_DB" >&2
    exit 1
fi

# Auto-refresh all provider tokens before running
"$TAGSLUT_TOOLS_DIR/auth" all 2>/dev/null || true

CMD=("$TAGSLUT_TOOLS_DIR/tagslut" index enrich \
    --db "$TAGSLUT_DB" \
    --hoarding \
    --retry-no-match \
    --verbose \
    --execute)

if [[ $# -gt 0 ]]; then
    CMD+=("$@")
fi

exec "${CMD[@]}"
