#!/usr/bin/env bash
# get-sync — deprecated Beatport compatibility alias for tools/get

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GET_INTAKE="$SCRIPT_DIR/get-intake"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_LOADER="$SCRIPT_DIR/_load_env.sh"

if [[ -f "$ENV_LOADER" ]]; then
  # shellcheck disable=SC1090
  source "$ENV_LOADER"
  load_workspace_env "$REPO_ROOT"
fi

usage() {
  echo "Usage: tools/get-sync <beatport-url> [extra args...]"
  echo "Deprecated: use tools/get <beatport-url> instead."
  exit 1
}

if [[ $# -lt 1 ]]; then
  usage
fi

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
fi

URL="$1"
shift

if [[ "$URL" != *"beatport.com"* ]]; then
  echo "Error: tools/get-sync only supports beatport.com URLs" >&2
  exit 2
fi

echo "Deprecated: tools/get-sync is a compatibility alias. Use tools/get $URL instead." >&2
exec "$SCRIPT_DIR/get" "$URL" "$@"
