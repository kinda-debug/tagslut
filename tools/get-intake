#!/usr/bin/env bash
# get-intake — advanced/backend intake pipeline for downloaded batches
#
# This is the lower-level engine behind tools/get.
#
# Pipeline:
#  1) Download via provider downloader (optional)
#  2) Quick duplicate check via tagslut index check (strict, non-interactive)
#  3) Fast trust scan + integrity registration
#  4) Cross-root fingerprint audit against final library
#  5) Build promote/stash/quarantine plans
#  6) Optionally execute move plans (move-only semantics)
#
# Default behavior is safe: plans only (no moves) unless --execute is passed.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_LOADER="$SCRIPT_DIR/_load_env.sh"

if [[ -f "$ENV_LOADER" ]]; then
  # shellcheck disable=SC1090
  source "$ENV_LOADER"
  load_workspace_env "$REPO_ROOT"
fi

GET_BIN="$SCRIPT_DIR/get"
TIDDL_WRAPPER="$SCRIPT_DIR/tiddl"
SCAN_SCRIPT="$SCRIPT_DIR/review/scan_with_trust.py"
AUDIT_SCRIPT="$SCRIPT_DIR/review/audio_dupe_audit.py"
PLAN_SCRIPT="$SCRIPT_DIR/review/plan_fpcalc_promote_unique_to_final_library.py"
MOVE_SCRIPT="$SCRIPT_DIR/review/move_from_plan.py"
PROCESS_ROOT_SCRIPT="$SCRIPT_DIR/review/process_root.py"
PRE_DOWNLOAD_CHECK_SCRIPT="$SCRIPT_DIR/review/pre_download_check.py"
POST_MOVE_ENRICH_SCRIPT="$SCRIPT_DIR/review/post_move_enrich_art.py"
BPDL_BIN="$SCRIPT_DIR/beatportdl/bpdl/bpdl"
BPDL_CONFIG="$SCRIPT_DIR/beatportdl/bpdl/beatportdl-config.yml"

AUTO_DB_AMBIGUOUS=0
AUTO_DB_CANDIDATES=()

usage() {
  cat <<'EOF'
Usage:
  tools/get-intake [options] <url> [-- downloader-args...]
  tools/get-intake --no-download --batch-root <path> [options]
  tools/get-intake --m3u-only (--url <beatport-url> | --playlist-file <file>) [options]
  tools/get-intake <provider-url>   # auto: use provider download root when --batch-root omitted

Note:
  tools/get is the primary user-facing downloader.
  tools/get-intake is the advanced/backend command for existing batch roots,
  m3u-only workflows, and direct pipeline control.

Options:
  --batch-root PATH    Download batch root to process (default: $ROOT_BP/$ROOT_TD or $VOLUME_STAGING/<provider>)
  --source TEXT        Source label (bpdl|tidal). Auto-inferred from URL if omitted.
  --url URL            Source URL (alternative to positional URL)
  --db PATH            SQLite DB path (default: $TAGSLUT_DB or auto-detected tagslut_db epoch; errors if ambiguous)
  --library-root PATH  Final library root (default: $LIBRARY_ROOT or $VOLUME_LIBRARY or $MASTER_LIBRARY)
  --fix-root PATH      Quarantine/FIX root (default: $FIX_ROOT or $VOLUME_QUARANTINE or artifacts/quarantine)
  --out-dir PATH       Output directory for plans (default: $TAGSLUT_ARTIFACTS/compare or artifacts/compare)
  --workers N          Fingerprint workers (default: 7)
  --trust N            Pre-scan trust score 0..3 (default: 3)
  --trust-post N       Post-scan trust score 0..3 (default: 3)
  --library-tag TEXT   Library tag used in scan_with_trust (default: INTAKE)
  --providers TEXT     Metadata providers for enrichment
  --verbose            Print internal paths, artifacts, and batch snapshots
  --execute            Execute move plans (default: dry-run planning only)
  --m3u                Generate Roon-friendly merged M3U from promoted files
  --m3u-dir PATH       M3U output dir (default: $PLAYLIST_ROOT or library root)
  --dj                 Transcode promoted FLACs to MP3 into DJ library root and write DJ playlists
  --dj-root PATH       DJ MP3 root (default: $DJ_MP3_ROOT or $DJ_LIBRARY)
  --dj-m3u-dir PATH    DJ playlist output dir (default: $DJ_PLAYLIST_ROOT or DJ root)
  --m3u-only           Only generate merged M3U (skip download/scan/move stages)
  --playlist-file PATH Build M3U from playlist file (.m3u/.m3u8/.txt/.csv/.json)
  --missing-policy MODE
                       Missing handling for --m3u-only: ask|report|skip|download (default: report)
  --no-download        Skip downloader step; process existing batch root
  --skip-mgmt-check    Skip quick duplicate check stage (legacy flag name)
  --hoard              Alias for tagging/enrich/art pipeline (default)
  --no-hoard           Alias for --no-tagging
  --no-tagging         Skip tagging / metadata enrich / cover-art steps
  --no-precheck        Skip pre-download DB check for Tidal/Beatport URLs
  --force-download     Keep matched tracks instead of skipping same/better inventory matches
  --skip-beatport-prefilter
                       Deprecated alias for --no-precheck
  -h, --help           Show this help

Examples:
  tools/get-intake "https://www.beatport.com/chart/.../12345"

  tools/get-intake --batch-root "$ROOT_BP" \
    "https://www.beatport.com/release/.../12345"

  tools/get-intake --no-download --batch-root "$STAGING_ROOT/clean" --execute

  tools/get-intake --m3u-only --m3u --url "https://www.beatport.com/chart/.../12345"
EOF
}

err() {
  echo "ERROR: $*" >&2
  exit 2
}

step() {
  local idx="$1"
  local total="$2"
  local label="$3"
  echo
  echo "[$idx/$total] $label"
}

run_cmd() {
  printf '→ '
  printf '%q ' "$@"
  printf '\n'
  "$@"
}

count_audio_files() {
  local root="${1:-}"
  if [[ -z "$root" || ! -d "$root" ]]; then
    echo "0"
    return 0
  fi
  find "$root" -type f \( \
    -iname '*.flac' -o \
    -iname '*.mp3' -o \
    -iname '*.wav' -o \
    -iname '*.aif' -o \
    -iname '*.aiff' -o \
    -iname '*.m4a' \
  \) | wc -l | tr -d ' '
}

preview_file_lines() {
  local path="${1:-}"
  local limit="${2:-5}"
  if [[ -z "$path" || ! -f "$path" ]]; then
    return 0
  fi
  awk -v limit="$limit" 'NF {print "    " $0; shown += 1; if (shown >= limit) exit}' "$path"
}

print_batch_snapshot() {
  local label="${1:-Batch}"
  local root="${2:-}"
  if [[ -z "$root" ]]; then
    echo "$label: root unset"
    return 0
  fi
  if [[ ! -d "$root" ]]; then
    echo "$label: missing ($root)"
    return 0
  fi

  local audio_count
  local flac_count
  local mp3_count
  audio_count="$(count_audio_files "$root")"
  flac_count="$(find "$root" -type f -iname '*.flac' | wc -l | tr -d ' ')"
  mp3_count="$(find "$root" -type f -iname '*.mp3' | wc -l | tr -d ' ')"

  echo "$label: root=$root audio=$audio_count flac=$flac_count mp3=$mp3_count"
  local sample_file=""
  while IFS= read -r sample_file; do
    [[ -n "$sample_file" ]] || continue
    echo "    $sample_file"
  done < <(find "$root" -type f \( \
      -iname '*.flac' -o \
      -iname '*.mp3' -o \
      -iname '*.wav' -o \
      -iname '*.aif' -o \
      -iname '*.aiff' -o \
      -iname '*.m4a' \
    \) | sort | tail -n 5)
}

safe_m3u_name() {
  local value="${1:-}"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g')"
  [[ -n "$value" ]] || value="playlist"
  echo "$value"
}

playlist_label_from_url() {
  local clean="${1%%\?*}"
  clean="${clean%/}"
  local last="${clean##*/}"
  local parent="${clean%/*}"
  local slug="${parent##*/}"

  case "$slug" in
    chart|release|releases|playlist|playlists|track|tracks|library|"")
      slug=""
      ;;
  esac

  if [[ -z "$slug" ]]; then
    slug="beatport-${last:-playlist}"
  fi
  safe_m3u_name "$slug"
}

rename_latest_m3u_from_marker() {
  local m3u_dir="$1"
  local marker_file="$2"
  local base_name="$3"
  local name_prefix="${4:-}"
  local name_suffix="${5:-}"

  [[ -d "$m3u_dir" ]] || return 0
  [[ -f "$marker_file" ]] || return 0
  [[ -n "$base_name" ]] || return 0

  local latest_new_m3u
  latest_new_m3u="$(find "$m3u_dir" -maxdepth 1 -type f -name '*.m3u' -newer "$marker_file" -print | sort | tail -n1 || true)"
  [[ -n "$latest_new_m3u" ]] || return 0

  local target="$m3u_dir/${name_prefix}${base_name}${name_suffix}.m3u"
  if [[ "$latest_new_m3u" != "$target" ]]; then
    if [[ -f "$latest_new_m3u" ]]; then
      mv -f "$latest_new_m3u" "$target" || true
      if [[ -f "$target" ]]; then
        echo "Named playlist: $target"
      fi
    fi
  fi
}

latest_file_after_marker() {
  local search_dir="$1"
  local marker_file="$2"
  local pattern="${3:-*.m3u}"

  [[ -d "$search_dir" ]] || return 0
  [[ -f "$marker_file" ]] || return 0
  find "$search_dir" -maxdepth 1 -type f -name "$pattern" -newer "$marker_file" -print | sort | tail -n1 || true
}

bpdl_downloads_dir_from_config() {
  if [[ ! -f "$BPDL_CONFIG" ]]; then
    echo ""
    return 0
  fi
  local raw
  raw="$(sed -n 's/^downloads_directory:[[:space:]]*//p' "$BPDL_CONFIG" | head -n1)"
  raw="${raw%\"}"
  raw="${raw#\"}"
  raw="${raw%\'}"
  raw="${raw#\'}"
  echo "$raw"
}

tiddl_downloads_dir_from_config() {
  local cfg=""
  local candidate=""
  for candidate in "$HOME/.tiddl" "$HOME/tiddl.json" "$HOME/Documents/tiddl.json"; do
    if [[ -f "$candidate" ]]; then
      cfg="$candidate"
      break
    fi
  done
  if [[ -z "$cfg" ]]; then
    echo ""
    return 0
  fi
  python3 - "$cfg" <<'PY'
import json
import sys
from pathlib import Path

cfg = Path(sys.argv[1]).expanduser()
try:
    payload = json.loads(cfg.read_text(encoding="utf-8"))
except Exception:
    print("")
    raise SystemExit(0)

download = payload.get("download") or {}
print(download.get("path") or "")
PY
}

first_nonempty() {
  local value=""
  for value in "$@"; do
    if [[ -n "${value:-}" ]]; then
      printf '%s\n' "$value"
      return 0
    fi
  done
  return 1
}

resolve_path() {
  python3 - "$1" <<'PY'
from pathlib import Path
import sys

print(Path(sys.argv[1]).expanduser().resolve())
PY
}

default_batch_root() {
  local staging_root=""
  local bpdl_root=""
  local tiddl_root=""
  staging_root="$(first_nonempty "${STAGING_ROOT:-}" "${VOLUME_STAGING:-}")"
  bpdl_root="$(bpdl_downloads_dir_from_config)"
  tiddl_root="$(tiddl_downloads_dir_from_config)"
  if [[ "${SOURCE:-}" == "tidal" ]]; then
    first_nonempty \
      "${BATCH_ROOT:-}" \
      "${ROOT_TD:-}" \
      "${TIDDL_DOWNLOAD_ROOT:-}" \
      "${tiddl_root:-}" \
      "${staging_root:+$staging_root/tidal}" \
      "$HOME/Downloads/tiddl" \
      "$REPO_ROOT/output/downloads/tidal"
    return 0
  fi
  first_nonempty \
    "${BATCH_ROOT:-}" \
    "${ROOT_BP:-}" \
    "${bpdl_root:-}" \
    "${staging_root:+$staging_root/bpdl}" \
    "$REPO_ROOT/output/downloads/bpdl"
}

default_library_root() {
  first_nonempty \
    "${LIBRARY_ROOT:-}" \
    "${VOLUME_LIBRARY:-}" \
    "${MASTER_LIBRARY:-}"
}

default_fix_root() {
  first_nonempty \
    "${FIX_ROOT:-}" \
    "${VOLUME_QUARANTINE:-}" \
    "$REPO_ROOT/artifacts/quarantine"
}

default_out_dir() {
  local artifacts_root=""
  artifacts_root="$(first_nonempty "${TAGSLUT_ARTIFACTS:-}" "$REPO_ROOT/artifacts")"
  first_nonempty \
    "${OUT_DIR:-}" \
    "${TAGSLUT_COMPARE_DIR:-}" \
    "${artifacts_root:+$artifacts_root/compare}" \
    "$REPO_ROOT/artifacts/compare"
}

default_m3u_dir() {
  first_nonempty \
    "${M3U_DIR:-}" \
    "${PLAYLIST_ROOT:-}" \
    "${TAGSLUT_PLAYLIST_ROOT:-}" \
    "${LIBRARY_ROOT:-}"
}

default_dj_m3u_dir() {
  first_nonempty \
    "${DJ_M3U_DIR:-}" \
    "${DJ_PLAYLIST_ROOT:-}" \
    "${DJ_ROOT:-}" \
    "${DJ_MP3_ROOT:-}" \
    "${DJ_LIBRARY:-}"
}

default_dj_root() {
  first_nonempty \
    "${DJ_MP3_ROOT:-}" \
    "${DJ_LIBRARY:-}"
}

autodetect_db_path() {
  local candidates=()

  if [[ -d "$REPO_ROOT/../tagslut_db" ]]; then
    while IFS= read -r file; do
      [[ -n "$file" ]] && candidates+=("$file")
    done < <(find "$REPO_ROOT/../tagslut_db" -type f \( -name music.db -o -name music_v2.db -o -name music_v3.db \) 2>/dev/null || true)
  fi

  if [[ -d "$HOME/Projects/tagslut_db" ]]; then
    while IFS= read -r file; do
      [[ -n "$file" ]] && candidates+=("$file")
    done < <(find "$HOME/Projects/tagslut_db" -type f \( -name music.db -o -name music_v2.db -o -name music_v3.db \) 2>/dev/null || true)
  fi

  if [[ ${#candidates[@]} -eq 0 ]]; then
    AUTO_DB_AMBIGUOUS=0
    AUTO_DB_CANDIDATES=()
    echo ""
    return 0
  fi

  AUTO_DB_CANDIDATES=("${candidates[@]}")

  if [[ ${#candidates[@]} -gt 1 ]]; then
    AUTO_DB_AMBIGUOUS=1
    echo ""
    return 0
  fi

  AUTO_DB_AMBIGUOUS=0
  echo "${candidates[0]}"
}

ensure_bpdl_download_target() {
  local target
  target="$(bpdl_downloads_dir_from_config)"
  if [[ -z "$target" ]]; then
    return 0
  fi

  local parent
  parent="$(dirname "$target")"
  if [[ ! -d "$parent" ]]; then
    err "Beatport downloads_directory parent is missing: $parent (from $BPDL_CONFIG). Mount the volume or update downloads_directory."
  fi

  mkdir -p "$target" || err "Cannot create Beatport downloads_directory: $target"
  [[ -d "$target" ]] || err "Beatport downloads_directory is not accessible: $target"
}

run_bpdl_batch() {
  local url_list="$1"
  local log_file="$2"
  shift 2
  local extra_args=("$@")

  ensure_bpdl_download_target

  local supports_quit=0
  if "$BPDL_BIN" -h 2>&1 | grep -q -- "-q"; then
    supports_quit=1
  fi

  if [[ "$supports_quit" -eq 1 ]]; then
    if [[ ${#extra_args[@]} -gt 0 ]]; then
      run_cmd "$BPDL_BIN" -q "${extra_args[@]}" "$url_list"
    else
      run_cmd "$BPDL_BIN" -q "$url_list"
    fi
    return 0
  fi

  echo "bpdl '-q' not supported by this binary; using compatibility mode."
  set +e
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    printf '→ '
    printf '%q ' "$BPDL_BIN" "${extra_args[@]}" "$url_list"
    printf '\n'
    "$BPDL_BIN" "${extra_args[@]}" "$url_list" < /dev/null 2>&1 | tee "$log_file"
  else
    printf '→ '
    printf '%q ' "$BPDL_BIN" "$url_list"
    printf '\n'
    "$BPDL_BIN" "$url_list" < /dev/null 2>&1 | tee "$log_file"
  fi
  local bpdl_code=${PIPESTATUS[0]}
  set -e

  if [[ "$bpdl_code" -ne 0 ]]; then
    if grep -q "Error reading input string: EOF" "$log_file"; then
      echo "bpdl exited after EOF prompt in non-interactive mode; continuing."
      return 0
    fi
    echo "bpdl failed (exit=$bpdl_code). See log: $log_file" >&2
    return "$bpdl_code"
  fi

  return 0
}

infer_source() {
  local url="$1"
  case "$url" in
    *beatport.com*) echo "bpdl" ;;
    *tidal.com*) echo "tidal" ;;
    *) echo "" ;;
  esac
}

download_step_label() {
  case "${SOURCE:-}" in
    bpdl) echo "Download from Beatport" ;;
    tidal) echo "Download from Tidal" ;;
    *) echo "Download from provider" ;;
  esac
}

DOWNLOAD=1
EXECUTE=0
SKIP_MGMT_CHECK=0
SKIP_PRECHECK=0
FORCE_DOWNLOAD=0
M3U_MODE=0
M3U_ONLY=0
DJ_MODE=0
TAGGING_MODE=1
VERBOSE=0

URL=""
BATCH_ROOT=""
SOURCE=""
DB_PATH="${TAGSLUT_DB:-}"
LIBRARY_ROOT="${LIBRARY_ROOT:-}"
FIX_ROOT="${FIX_ROOT:-}"
OUT_DIR="${TAGSLUT_COMPARE_DIR:-}"
WORKERS=7
TRUST=3
TRUST_POST=3
LIBRARY_TAG="INTAKE"
M3U_DIR=""
DJ_M3U_DIR="${DJ_PLAYLIST_ROOT:-}"
PLAYLIST_FILE=""
MISSING_POLICY="report"
DJ_ROOT="${DJ_MP3_ROOT:-${DJ_LIBRARY:-}}"
ENRICH_PROVIDERS="beatport,tidal,deezer,traxsource,musicbrainz"
ROON_PLAYLIST_PREFIX="${ROON_PLAYLIST_PREFIX:-roon-}"
ROON_PLAYLIST_SUFFIX="${ROON_PLAYLIST_SUFFIX:-}"
DJ_PLAYLIST_PREFIX="${DJ_PLAYLIST_PREFIX:-dj-}"
DJ_PLAYLIST_SUFFIX="${DJ_PLAYLIST_SUFFIX:-}"

DOWNLOADER_ARGS=()
BATCH_AUDIO_START=0
BATCH_AUDIO_END=0
ROON_M3U_OUTPUT=""
DJ_M3U_OUTPUT=""
DJ_EXPORT_COUNT=0
POST_MOVE_PID=""
POST_MOVE_LOG=""
PREFILTER_KEEP=0
PREFILTER_SKIP=0
PREFILTER_TOTAL=0
PROMOTE_MOVE=0
STASH_MOVE=0
QUARANTINE_MOVE=0
PROMOTED_FLACS_COUNT=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --batch-root)
      [[ $# -ge 2 ]] || err "--batch-root requires a value"
      BATCH_ROOT="$2"
      shift 2
      ;;
    --source)
      [[ $# -ge 2 ]] || err "--source requires a value"
      SOURCE="$2"
      shift 2
      ;;
    --url)
      [[ $# -ge 2 ]] || err "--url requires a value"
      URL="$2"
      shift 2
      ;;
    --db)
      [[ $# -ge 2 ]] || err "--db requires a value"
      DB_PATH="$2"
      shift 2
      ;;
    --library-root)
      [[ $# -ge 2 ]] || err "--library-root requires a value"
      LIBRARY_ROOT="$2"
      shift 2
      ;;
    --fix-root)
      [[ $# -ge 2 ]] || err "--fix-root requires a value"
      FIX_ROOT="$2"
      shift 2
      ;;
    --out-dir)
      [[ $# -ge 2 ]] || err "--out-dir requires a value"
      OUT_DIR="$2"
      shift 2
      ;;
    --workers)
      [[ $# -ge 2 ]] || err "--workers requires a value"
      WORKERS="$2"
      shift 2
      ;;
    --trust)
      [[ $# -ge 2 ]] || err "--trust requires a value"
      TRUST="$2"
      shift 2
      ;;
    --trust-post)
      [[ $# -ge 2 ]] || err "--trust-post requires a value"
      TRUST_POST="$2"
      shift 2
      ;;
    --library-tag)
      [[ $# -ge 2 ]] || err "--library-tag requires a value"
      LIBRARY_TAG="$2"
      shift 2
      ;;
    --providers)
      [[ $# -ge 2 ]] || err "--providers requires a value"
      ENRICH_PROVIDERS="$2"
      shift 2
      ;;
    --verbose)
      VERBOSE=1
      shift
      ;;
    --execute)
      EXECUTE=1
      shift
      ;;
    --m3u)
      M3U_MODE=1
      shift
      ;;
    --m3u-only)
      M3U_ONLY=1
      M3U_MODE=1
      shift
      ;;
    --m3u-dir)
      [[ $# -ge 2 ]] || err "--m3u-dir requires a value"
      M3U_DIR="$2"
      shift 2
      ;;
    --dj)
      DJ_MODE=1
      shift
      ;;
    --dj-root)
      [[ $# -ge 2 ]] || err "--dj-root requires a value"
      DJ_ROOT="$2"
      shift 2
      ;;
    --dj-m3u-dir)
      [[ $# -ge 2 ]] || err "--dj-m3u-dir requires a value"
      DJ_M3U_DIR="$2"
      shift 2
      ;;
    --playlist-file)
      [[ $# -ge 2 ]] || err "--playlist-file requires a value"
      PLAYLIST_FILE="$2"
      shift 2
      ;;
    --missing-policy)
      [[ $# -ge 2 ]] || err "--missing-policy requires a value"
      MISSING_POLICY="$2"
      shift 2
      ;;
    --no-download)
      DOWNLOAD=0
      shift
      ;;
    --skip-mgmt-check)
      SKIP_MGMT_CHECK=1
      shift
      ;;
    --hoard)
      TAGGING_MODE=1
      shift
      ;;
    --no-hoard|--no-tagging)
      TAGGING_MODE=0
      shift
      ;;
    --no-precheck|--skip-beatport-prefilter)
      SKIP_PRECHECK=1
      shift
      ;;
    --force-download)
      FORCE_DOWNLOAD=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      DOWNLOADER_ARGS+=("$@")
      break
      ;;
    -*)
      err "Unknown option: $1"
      ;;
    *)
      if [[ -z "$URL" ]]; then
        URL="$1"
      else
        DOWNLOADER_ARGS+=("$1")
      fi
      shift
      ;;
  esac
done

if [[ -z "$SOURCE" && -n "$URL" ]]; then
  SOURCE="$(infer_source "$URL")"
fi
[[ -n "$SOURCE" ]] || SOURCE="ingest"

if [[ "$M3U_ONLY" -eq 0 && -n "$URL" && -z "$BATCH_ROOT" ]]; then
  BATCH_ROOT="$(default_batch_root || true)"
  [[ -n "$BATCH_ROOT" ]] || err "No batch root configured. Set --batch-root or VOLUME_STAGING."
  echo "Auto mode: no --batch-root provided; using batch root: $BATCH_ROOT"
fi

if [[ -z "$DB_PATH" ]]; then
  DB_PATH="$(autodetect_db_path)"
fi
if [[ -z "$DB_PATH" ]]; then
  if [[ "${AUTO_DB_AMBIGUOUS:-0}" -eq 1 ]]; then
    echo "Multiple DB candidates found:" >&2
    printf '  - %s\n' "${AUTO_DB_CANDIDATES[@]}" >&2
    err "Set --db or TAGSLUT_DB to choose the correct DB."
  fi
  err "Missing DB path. Set --db or TAGSLUT_DB."
fi
[[ "$TRUST" =~ ^[0-3]$ ]] || err "--trust must be 0,1,2,3"
[[ "$TRUST_POST" =~ ^[0-3]$ ]] || err "--trust-post must be 0,1,2,3"
[[ "$WORKERS" =~ ^[0-9]+$ ]] || err "--workers must be an integer"
case "$MISSING_POLICY" in
  ask|report|skip|download) ;;
  *) err "--missing-policy must be one of: ask, report, skip, download" ;;
esac

if [[ "$M3U_ONLY" -eq 1 ]]; then
  if [[ -z "$URL" && -z "$PLAYLIST_FILE" ]]; then
    err "--m3u-only requires either URL or --playlist-file"
  fi
else
  [[ -n "$BATCH_ROOT" ]] || err "--batch-root is required"
  if [[ "$DOWNLOAD" -eq 1 && -z "$URL" ]]; then
    err "URL is required unless --no-download is used"
  fi
fi

[[ -x "$GET_BIN" ]] || err "Missing executable: $GET_BIN"
[[ -x "$BPDL_BIN" ]] || err "Missing executable: $BPDL_BIN"
