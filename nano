#!/usr/bin/env python3

import os
import sys
import csv
import shutil
import subprocess
import xml.etree.ElementTree as ET
from pathlib import Path

"""
Usage:

python rebuild_dj_from_xml.py \
    --xml DJ.xml \
    --flac-root /Volumes/MUSIC/MUSIC_MASTER_FLAC \
    --out /Volumes/MUSIC/DJ_LIBRARY_MP3_CLEAN \
    --report dj_rebuild_report.csv
"""

import argparse

parser = argparse.ArgumentParser()
parser.add_argument("--xml", required=True)
parser.add_argument("--flac-root", required=True)
parser.add_argument("--out", required=True)
parser.add_argument("--report", required=True)
args = parser.parse_args()

XML_PATH = Path(args.xml)
FLAC_ROOT = Path(args.flac_root)
OUT_ROOT = Path(args.out)
REPORT_PATH = Path(args.report)

OUT_ROOT.mkdir(parents=True, exist_ok=True)

def normalize(s):
    return "".join(c.lower() for c in s if c.isalnum())

def extract_tracks(xml_path):
    tree = ET.parse(xml_path)
    root = tree.getroot()
    tracks = []

    for track in root.iter("TRACK"):
        artist = track.attrib.get("ARTIST", "")
        name = track.attrib.get("NAME", "")
        location = track.attrib.get("LOCATION", "")
        isrc = track.attrib.get("ISRC", "")
        total_time = track.attrib.get("TOTAL_TIME", "")

        tracks.append({
            "artist": artist,
            "title": name,
            "location": location,
            "isrc": isrc,
            "duration_ms": total_time
        })

    return tracks

def build_flac_index(root):
    index = {}
    for path in root.rglob("*.flac"):
        key = normalize(path.stem)
        index[key] = path
    return index

def get_cover_from_flac(flac_path, out_image):
    cmd = [
        "metaflac",
        "--export-picture-to=" + str(out_image),
        str(flac_path)
    ]
    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def encode_mp3(flac_path, mp3_out):
    cmd = [
        "ffmpeg",
        "-y",
        "-i", str(flac_path),
        "-map_metadata", "0",
        "-vn",
        "-ar", "44100",
        "-codec:a", "libmp3lame",
        "-b:a", "320k",
        "-write_id3v1", "1",
        "-id3v2_version", "3",
        str(mp3_out)
    ]
    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def embed_cover(mp3_path, cover_path):
    if not cover_path.exists():
        return
    temp = mp3_path.with_suffix(".tmp.mp3")
    cmd = [
        "ffmpeg",
        "-y",
        "-i", str(mp3_path),
        "-i", str(cover_path),
        "-map", "0:0",
        "-map", "1:0",
        "-codec", "copy",
        "-id3v2_version", "3",
        "-metadata:s:v", "title=Album cover",
        "-metadata:s:v", "comment=Cover (front)",
        str(temp)
    ]
    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    temp.replace(mp3_path)

tracks = extract_tracks(XML_PATH)
flac_index = build_flac_index(FLAC_ROOT)

report_rows = []

for t in tracks:
    key = normalize(t["title"])
    flac_path = flac_index.get(key)

    if not flac_path:
        report_rows.append([t["artist"], t["title"], "NOT_FOUND"])
        continue

    artist_dir = OUT_ROOT / t["artist"]
    artist_dir.mkdir(parents=True, exist_ok=True)

    mp3_out = artist_dir / (flac_path.stem + ".mp3")

    encode_mp3(flac_path, mp3_out)

    cover_tmp = mp3_out.with_suffix(".jpg")
    get_cover_from_flac(flac_path, cover_tmp)
    embed_cover(mp3_out, cover_tmp)

    if cover_tmp.exists():
        cover_tmp.unlink()

    report_rows.append([t["artist"], t["title"], "OK"])

with open(REPORT_PATH, "w", newline="") as f:
    writer = csv.writer(f)
    writer.writerow(["Artist", "Title", "Status"])
    writer.writerows(report_rows)

print("Done.")
print(f"Report written to {REPORT_PATH}")
