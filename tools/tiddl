#!/usr/bin/env bash
# tiddl — Wrapper script for system-installed TIDDL (Tidal Downloader)
#
# This wrapper calls the system-installed tiddl binary by default.
# Override the binary path by setting TIDDL_BIN environment variable.
#
# Usage:
#   tools/tiddl <url>                    # Uses /opt/homebrew/bin/tiddl
#   TIDDL_BIN=/custom/path/tiddl tools/tiddl <url>  # Uses custom binary
#
# After downloading, register to inventory and generate M3U:
#   tagslut index register ~/Downloads/tiddl/ --source tidal
#   tagslut report m3u ~/Downloads/tiddl/

set -euo pipefail

TIDDL_BIN="${TIDDL_BIN:-/opt/homebrew/bin/tiddl}"

if [[ ! -x "$TIDDL_BIN" ]]; then
    if command -v tiddl >/dev/null 2>&1; then
        TIDDL_BIN="$(command -v tiddl)"
    else
        echo "Error: tiddl binary not found or not executable at: $TIDDL_BIN" >&2
        echo "Set TIDDL_BIN or install tiddl in PATH." >&2
        exit 1
    fi
fi

if [[ $# -eq 0 ]]; then
    exec "$TIDDL_BIN"
fi

case "$1" in
    auth|download|--help|-h|--debug|--omit-cache)
        exec "$TIDDL_BIN" "$@"
        ;;
    *)
        # Newer tiddl CLI expects: tiddl download url <url>
        exec "$TIDDL_BIN" download url "$@"
        ;;
esac
