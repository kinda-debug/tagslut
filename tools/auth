#!/usr/bin/env bash
# auth — Refresh all provider tokens and sync to downstream tools.
#
# Usage:
#   tools/auth           # refresh all (tidal, beatport, qobuz)
#   tools/auth tidal     # refresh TIDAL only
#   tools/auth beatport  # refresh Beatport only
#   tools/auth qobuz     # refresh Qobuz app credentials + sync to streamrip

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_LOADER="$SCRIPT_DIR/_load_env.sh"
export PATH="$HOME/.local/bin:$PATH"

if [[ -f "$ENV_LOADER" ]]; then
    source "$ENV_LOADER" 2>/dev/null
    load_workspace_env "$REPO_ROOT" 2>/dev/null
fi

cd "$REPO_ROOT"

PROVIDER="${1:-all}"

STREAMRIP_CONFIG="/Users/georgeskhawam/Projects/streamrip/dev_config.toml"
TOKENS_FILE="$HOME/.config/tagslut/tokens.json"

sync_qobuz_to_streamrip() {
    [[ -f "$STREAMRIP_CONFIG" ]] || return 0
    [[ -f "$TOKENS_FILE" ]] || return 0
    python3 - "$STREAMRIP_CONFIG" "$TOKENS_FILE" << 'PYEOF'
import json, re, sys
cfg_path, tok_path = sys.argv[1], sys.argv[2]
tokens = json.load(open(tok_path))
q = tokens.get("qobuz", {})
user_token = q.get("user_auth_token", "")
user_id = q.get("user_id", "")
if not (user_token and user_id):
    sys.exit(0)
cfg = open(cfg_path).read()
cfg = re.sub(r'use_auth_token = \w+', 'use_auth_token = true', cfg)
cfg = re.sub(r'email_or_userid = ".*?"', f'email_or_userid = "{user_id}"', cfg)
cfg = re.sub(r'password_or_token = ".*?"', f'password_or_token = "{user_token}"', cfg)
open(cfg_path, "w").write(cfg)
PYEOF
}

refresh_tidal() {
    echo -n "TIDAL... "
    tiddl auth refresh 2>/dev/null && echo "OK" || echo "FAILED"
}

refresh_beatport() {
    echo -n "Beatport... "
    poetry run python -m tagslut auth refresh beatport 2>/dev/null && echo "OK" || echo "FAILED"
}

refresh_qobuz() {
    echo -n "Qobuz... "
    poetry run python -m tagslut auth refresh qobuz 2>/dev/null \
        && sync_qobuz_to_streamrip \
        && echo "OK" \
        || echo "FAILED"
}

case "$PROVIDER" in
    all)
        refresh_tidal
        refresh_beatport
        refresh_qobuz
        ;;
    tidal)    refresh_tidal ;;
    beatport) refresh_beatport ;;
    qobuz)    refresh_qobuz ;;
    *)
        echo "Unknown provider: $PROVIDER" >&2
        echo "Usage: tools/auth [all|tidal|beatport|qobuz]" >&2
        exit 1
        ;;
esac
