#!/usr/bin/env bash
# enrich — Run metadata hoarding enrichment against the active DB.
#
# Usage:
#   tools/enrich              # enrich all unenriched/unmatched tracks
#   tools/enrich --force      # re-enrich everything
#   tools/enrich --limit N    # cap at N tracks
#   tools/enrich --verbose    # show per-track debug output
#
# Reads TAGSLUT_DB from environment (set by env_exports.sh).
# Providers: beatport → tidal → qobuz (in priority order).
# All provider tokens are refreshed automatically before each run.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_LOADER="$SCRIPT_DIR/_load_env.sh"

if [[ -f "$ENV_LOADER" ]]; then
    source "$ENV_LOADER" 2>/dev/null
    load_workspace_env "$REPO_ROOT" 2>/dev/null
fi

if [[ -z "${TAGSLUT_DB:-}" ]]; then
    echo "Error: TAGSLUT_DB is not set. Run: source env_exports.sh" >&2
    exit 1
fi

if [[ ! -f "$TAGSLUT_DB" ]]; then
    echo "Error: DB not found: $TAGSLUT_DB" >&2
    exit 1
fi

cd "$REPO_ROOT"

# Auto-refresh all provider tokens before running
"$SCRIPT_DIR/auth" all 2>/dev/null || true

CMD=(poetry run python -m tagslut index enrich \
    --db "$TAGSLUT_DB" \
    --hoarding \
    --retry-no-match \
    --execute)

if [[ $# -gt 0 ]]; then
    CMD+=("$@")
fi

exec "${CMD[@]}"
