#!/usr/bin/env bash
# get — Unified intake/download entrypoint for provider URLs
#
# Routes URLs to the appropriate workflow based on domain:
#   - spotify.com  → tools/get-intake sync flow
#   - tidal.com    → tools/get-intake sync flow (or tools/tiddl for --simple)
#   - beatport.com → tools/get-intake sync flow (or bpdl for --simple)
#   - deezer.com   → tools/deemix (Deezer wrapper + auto-register)
#
# Usage:
#   tools/get [--sync|--synch|--simple|--enrich|--backfill] <url> [extra-args...]
#
# Examples:
#   tools/get https://open.spotify.com/playlist/37i9dQZF1DX4JAvHpjipBk
#   tools/get https://tidal.com/browse/playlist/12345
#   tools/get https://www.beatport.com/release/some-release/12345
#   tools/get https://listen.tidal.com/album/12345 --quality high
#   tools/get --backfill https://tidal.com/album/36689581/u
#
# Return playlist (alias):
#   tools/get --re <url|playlist-file|directory>
#
# After downloading, register to inventory and generate M3U:
#   tagslut index register <download-path> --source <tidal|bpdl>
#   tagslut report m3u <download-path>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TIDDL_WRAPPER="$SCRIPT_DIR/tiddl"
DEEMIX_WRAPPER="$SCRIPT_DIR/deemix"
GET_INTAKE="$SCRIPT_DIR/get-intake"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_LOADER="$SCRIPT_DIR/_load_env.sh"
UI_HELPER="$SCRIPT_DIR/_console_ui.sh"

if [[ -f "$UI_HELPER" ]]; then
    # shellcheck disable=SC1090
    source "$UI_HELPER"
    ui_init
fi

if [[ -f "$ENV_LOADER" ]]; then
    # Load repo-local .env so wrapper commands see TAGSLUT_DB and volume roots.
    # shellcheck disable=SC1090
    source "$ENV_LOADER"
    load_workspace_env "$REPO_ROOT"
fi

usage() {
    echo "Unified download wrapper for provider URLs."
    echo "Supports Spotify, TIDAL, Beatport, Qobuz, and Deezer."
    echo "Operator note: \`ts-get\` may exist as a local shell wrapper for \`tools/get\`."
    echo ""
    echo "Common usage:"
    echo "  tools/get <url>            download and process one provider URL"
    echo "  tools/get <url> --tag      fully enrich promoted FLACs in MASTER_LIBRARY"
    echo "  tools/get <url> --dj       build MP3 copies and add DJ pool playlists"
    echo "  tools/get --enrich <url>   run intake plus metadata/art enrichment"
    echo "  tools/get --backfill <url> download only missing tracks, then finish intake"
    echo ""
    echo "Common flags:"
    echo "  --tag                fully enrich promoted FLACs in MASTER_LIBRARY"
    echo "  --dj                 build MP3_LIBRARY copies and DJ pool playlists"
    echo "                       --dj implies --mp3."
    echo "  --mp3                build MP3_LIBRARY copies"
    echo "  --no-precheck        skip duplicate-quality precheck"
    echo "  --force-download     keep matched tracks anyway during precheck"
    echo "  --resume             reuse staged downloads when supported"
    echo "  --verbose            show detailed stage output and internal paths"
    echo ""
    echo "Compatibility / advanced:"
    echo "  --simple             downloader-only behavior"
    echo "  --re                 return playlist path from the intake flow"
    echo "  Routing:"
    echo "    TIDAL and Beatport use intake by default; --simple uses provider-native download."
    echo "    Qobuz uses streamrip + auto-register. Deezer uses deemix + auto-register."
    echo "  Use tools/get-help for the compact version of this help."
    exit 1
}

if [[ $# -lt 1 ]]; then
    usage
fi

MODE="auto"
RETURN_PLAYLIST=0
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    usage
elif [[ "$1" == "--sync" || "$1" == "--synch" ]]; then
    MODE="sync"
    shift
elif [[ "$1" == "--simple" ]]; then
    MODE="simple"
    shift
elif [[ "$1" == "--enrich" ]]; then
    MODE="enrich"
    shift
elif [[ "$1" == "--backfill" ]]; then
    # Backfill mode: download only missing tracks, then register + enrich (DJ tags always
    # included: BPM, key, energy, label, genre, art) + promote to MASTER_LIBRARY.
    # Existing files in the batch root are skipped by the downloader (--resume semantics).
    # No re-downloading. Pass any TIDAL or Beatport album/playlist URL.
    MODE="backfill"
    shift
elif [[ "$1" == "--re" ]]; then
    RETURN_PLAYLIST=1
    MODE="sync"
    shift
fi

if [[ $# -lt 1 ]]; then
    usage
fi

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    usage
fi

URL=""
PRE_URL_ARGS=()
INPUT_PATH=""
INPUT_ARGS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --re)
            RETURN_PLAYLIST=1
            shift
            ;;
        http://*|https://*|*spotify.com*|*tidal.com*|*beatport.com*|*deezer.com*|*dzr.page.link*|*qobuz.com*)
            URL="$1"
            shift
            break
            ;;
        *)
            PRE_URL_ARGS+=("$1")
            shift
            ;;
    esac
done

if [[ -z "$URL" ]]; then
    # Attempt to treat a local input (playlist file or directory) as the primary target.
    for arg in "${PRE_URL_ARGS[@]}" "$@"; do
        if [[ -z "$INPUT_PATH" && "$arg" != -* && -e "$arg" ]]; then
            INPUT_PATH="$arg"
            continue
        fi
        INPUT_ARGS+=("$arg")
    done
    if [[ -z "$INPUT_PATH" ]]; then
        usage
    fi
fi

if [[ ${#PRE_URL_ARGS[@]} -gt 0 ]]; then
    set -- "${PRE_URL_ARGS[@]}" "$@"
fi

for arg in "$@"; do
    if [[ "$arg" == "--re" ]]; then
        RETURN_PLAYLIST=1
        break
    fi
done
if [[ "$RETURN_PLAYLIST" -eq 1 && "$MODE" == "auto" ]]; then
    MODE="sync"
fi

if declare -F ui_header >/dev/null 2>&1; then
    ui_header "tagslut get"
    if [[ -n "$URL" ]]; then
        ui_status run "input=$URL mode=$MODE"
    elif [[ -n "$INPUT_PATH" ]]; then
        ui_status run "input=$INPUT_PATH mode=$MODE"
    fi
fi

INTAKE_CMD=()

build_intake_cmd() {
    local source="$1"
    local url="$2"
    shift 2

    local precheck_enabled=1
    local intake_args=()
    local wrapper_verbose=1
    local arg=""
    while [[ $# -gt 0 ]]; do
        arg="$1"
        case "$arg" in
            --missing-only)
                shift
                ;;
            --allow-duplicates)
                precheck_enabled=0
                shift
                ;;
            --force|-f)
                intake_args+=(--force-download)
                shift
                ;;
            --enrich|--hoard)
                shift
                ;;
            --re)
                RETURN_PLAYLIST=1
                shift
                ;;
            --dj)
                intake_args+=(--dj)
                shift
                ;;
            --resume)
                intake_args+=(--resume)
                shift
                ;;
            --verbose)
                wrapper_verbose=1
                intake_args+=(--verbose)
                shift
                ;;
            *)
                intake_args+=("$arg")
                shift
                ;;
        esac
    done

    INTAKE_CMD=("$GET_INTAKE" --source "$source" --missing-policy download --execute --m3u)
    if [[ "$MODE" == "enrich" || "$MODE" == "backfill" ]]; then
        INTAKE_CMD+=(--enrich)
    fi
    if [[ "$MODE" == "backfill" ]]; then
        # Resume mode: tiddl sees existing files and skips them; pipeline continues for all.
        INTAKE_CMD+=(--resume --force-download)
    fi
    if [[ "$precheck_enabled" -eq 0 ]]; then
        INTAKE_CMD+=(--no-precheck)
    fi
    INTAKE_CMD+=("$url")
    if [[ ${#intake_args[@]} -gt 0 ]]; then
        INTAKE_CMD+=("${intake_args[@]}")
    fi

    # Prefer rendering via the Python Rich wrapper in sync/enrich/backfill modes.
    if [[ -x "$REPO_ROOT/.venv/bin/python" ]]; then
        WRAPPED_INTAKE_CMD=("$REPO_ROOT/.venv/bin/python" -m tagslut.exec.get_intake_console)
        if [[ "$wrapper_verbose" -eq 1 ]]; then
            WRAPPED_INTAKE_CMD+=(--verbose)
        fi
        WRAPPED_INTAKE_CMD+=(-- "${INTAKE_CMD[@]}")
        INTAKE_CMD=("${WRAPPED_INTAKE_CMD[@]}")
    elif command -v python3 >/dev/null 2>&1; then
        WRAPPED_INTAKE_CMD=(python3 -m tagslut.exec.get_intake_console)
        if [[ "$wrapper_verbose" -eq 1 ]]; then
            WRAPPED_INTAKE_CMD+=(--verbose)
        fi
        WRAPPED_INTAKE_CMD+=(-- "${INTAKE_CMD[@]}")
        INTAKE_CMD=("${WRAPPED_INTAKE_CMD[@]}")
    fi
}

# Local input routing: playlist files and directories.
if [[ -n "$INPUT_PATH" ]]; then
    cd "$REPO_ROOT"

    if [[ -f "$INPUT_PATH" ]]; then
        ext="${INPUT_PATH##*.}"
        ext="$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')"
        case "$ext" in
            m3u|m3u8|txt|csv|json)
                # Playlist file: match/fill missing (when possible) and return playlist.
                INTAKE_CMD=(
                    "$GET_INTAKE"
                    --source mixed
                    --missing-policy download
                    --execute
                    --m3u
                    --m3u-only
                    --playlist-file "$INPUT_PATH"
                )
                if [[ ${#INPUT_ARGS[@]} -gt 0 ]]; then
                    INTAKE_CMD+=("${INPUT_ARGS[@]}")
                fi
                if [[ -x "$REPO_ROOT/.venv/bin/python" ]]; then
                    exec "$REPO_ROOT/.venv/bin/python" -m tagslut.exec.get_intake_console -- "${INTAKE_CMD[@]}"
                fi
                exec python3 -m tagslut.exec.get_intake_console -- "${INTAKE_CMD[@]}"
                ;;
            *)
                echo "Error: unsupported playlist file extension: .$ext" >&2
                exit 1
                ;;
        esac
    fi

    if [[ -d "$INPUT_PATH" ]]; then
        # Directory: canonical local-root processing. If --re was requested, attempt to return a playlist
        # from the most recent promoted cohort list; fallback to scanning the directory itself.
        PROC_CMD=(poetry run python -m tagslut intake process-root --root "$INPUT_PATH")
        if [[ ${#INPUT_ARGS[@]} -gt 0 ]]; then
            PROC_CMD+=("${INPUT_ARGS[@]}")
        fi
        "${PROC_CMD[@]}"

        if [[ "$RETURN_PLAYLIST" -eq 1 ]]; then
            PROMOTED_LIST="$(ls -1t "$REPO_ROOT"/artifacts/compare/promoted_audio_*.txt 2>/dev/null | head -n1 || true)"
            if [[ -n "$PROMOTED_LIST" && -f "$PROMOTED_LIST" ]]; then
                poetry run python -m tagslut report m3u --merge --path-mode relative --paths-file "$PROMOTED_LIST"
            else
                poetry run python -m tagslut report m3u --merge --path-mode relative "$INPUT_PATH"
            fi
        fi
        exit 0
    fi

    echo "Error: input does not exist: $INPUT_PATH" >&2
    exit 1
fi

# MP3/DJ routing: canonical intake owner.
if [[ -n "$URL" ]]; then
    ORIG_ARGS=("$@")
    WANTS_TAG=0
    WANTS_MP3=0
    WANTS_DJ=0
    MP3_ROOT_ARG=""
    WRAPPER_VERBOSE=1
    INTAKE_URL_FORWARD=()

    i=0
    while [[ $i -lt ${#ORIG_ARGS[@]} ]]; do
        arg="${ORIG_ARGS[$i]}"
        case "$arg" in
            --tag)
                WANTS_TAG=1
                ;;
            --mp3)
                WANTS_MP3=1
                ;;
            --dj)
                WANTS_DJ=1
                WANTS_MP3=1
                ;;
            --mp3-root)
                ((i++))
                MP3_ROOT_ARG="${ORIG_ARGS[$i]:-}"
                ;;
            --sync|--synch|--simple|--enrich|--backfill|--re)
                ;;
            --force|-f)
                INTAKE_URL_FORWARD+=(--force-download)
                ;;
            --no-precheck|--force-download|--db|--dry-run|--artifact-dir)
                INTAKE_URL_FORWARD+=("$arg")
                if [[ "$arg" == "--db" || "$arg" == "--artifact-dir" ]]; then
                    ((i++))
                    INTAKE_URL_FORWARD+=("${ORIG_ARGS[$i]:-}")
                fi
                ;;
            --verbose)
                WRAPPER_VERBOSE=1
                ;;
            --debug-raw)
                WRAPPER_VERBOSE=1
                ;;
            *)
                ;;
        esac
        ((i++))
    done

    if [[ "$WANTS_TAG" -eq 1 || "$WANTS_MP3" -eq 1 || "$WANTS_DJ" -eq 1 ]]; then
        if [[ "$URL" == *"qobuz.com"* ]]; then
            # Qobuz is routed through streamrip below; do not bypass it with the direct intake shortcut.
            :
        else
        cd "$REPO_ROOT"

        if [[ -z "$MP3_ROOT_ARG" && ( "$WANTS_MP3" -eq 1 || "$WANTS_DJ" -eq 1 ) ]]; then
            MP3_ROOT_ARG="${MP3_LIBRARY:-/Volumes/MUSIC/MP3_LIBRARY}"
        fi

        INTAKE_URL_CMD=(poetry run python -m tagslut intake url "$URL")
        if [[ "$WANTS_TAG" -eq 1 ]]; then
            INTAKE_URL_CMD+=(--tag)
        fi
        if [[ "$WANTS_DJ" -eq 1 ]]; then
            INTAKE_URL_CMD+=(--dj --mp3-root "$MP3_ROOT_ARG")
        elif [[ "$WANTS_MP3" -eq 1 ]]; then
            INTAKE_URL_CMD+=(--mp3 --mp3-root "$MP3_ROOT_ARG")
        fi

        if [[ "$WANTS_DJ" -eq 1 && "$URL" == *"tidal.com"* ]]; then
            PLAYLIST_NAME=""
            if [[ "$URL" == *"/playlist/"* ]]; then
                TIDAL_ID="${URL##*/playlist/}"
                PLAYLIST_NAME="$(
                    cd "$REPO_ROOT" && poetry run python3 -c "
from tagslut.metadata.auth import TokenManager
import requests, json
from pathlib import Path
tm = TokenManager(Path.home() / '.config/tagslut/tokens.json')
tok = tm.get_token('tidal')
access = tok.access_token if tok else ''
if not access:
    raise SystemExit
r = requests.get(f'https://openapi.tidal.com/v2/playlists/${TIDAL_ID}',
    headers={'Authorization': f'Bearer {access}', 'Accept': 'application/vnd.api+json'}, timeout=8)
d = r.json()
print((d.get('data') or {}).get('attributes', {}).get('name', ''))
" 2>/dev/null || true
                )"
            elif [[ "$URL" == *"/album/"* ]]; then
                TIDAL_ID="${URL##*/album/}"
                PLAYLIST_NAME="$(
                    cd "$REPO_ROOT" && poetry run python3 -c "
from tagslut.metadata.auth import TokenManager
import requests
from pathlib import Path
tm = TokenManager(Path.home() / '.config/tagslut/tokens.json')
tok = tm.get_token('tidal')
access = tok.access_token if tok else ''
if not access:
    raise SystemExit
r = requests.get(f'https://openapi.tidal.com/v2/albums/${TIDAL_ID}',
    headers={'Authorization': f'Bearer {access}', 'Accept': 'application/vnd.api+json'}, timeout=8)
print((r.json().get('data') or {}).get('attributes', {}).get('title', ''))
" 2>/dev/null || true
                )"
            fi

            if [[ -n "$PLAYLIST_NAME" ]]; then
                INTAKE_URL_CMD+=(--playlist-name "$PLAYLIST_NAME")
            fi
        fi

        if [[ "$WRAPPER_VERBOSE" -eq 1 ]]; then
            INTAKE_URL_CMD+=(--verbose --debug-raw)
        fi
        if [[ ${#INTAKE_URL_FORWARD[@]} -gt 0 ]]; then
            INTAKE_URL_CMD+=("${INTAKE_URL_FORWARD[@]}")
        fi

        exec "${INTAKE_URL_CMD[@]}"
        fi
    fi
fi

# Parse --dj / --mp3 flags globally for all providers
WANTS_DJ=0
WANTS_MP3=0
for __garg in "$@"; do
    [[ "$__garg" == "--dj" ]] && { WANTS_DJ=1; WANTS_MP3=1; }
    [[ "$__garg" == "--mp3" ]] && WANTS_MP3=1
done

# Route based on domain
if [[ "$URL" == *"spotify.com"* ]]; then
    if [[ ! -x "$GET_INTAKE" ]]; then
        echo "Error: get-intake not found or not executable at: $GET_INTAKE" >&2
        exit 1
    fi
    cd "$REPO_ROOT"
    build_intake_cmd "spotify" "$URL" "$@"
    exec "${INTAKE_CMD[@]}"

elif [[ "$URL" == *"tidal.com"* ]]; then
    if [[ ! -x "$GET_INTAKE" ]]; then
        echo "Error: get-intake not found or not executable at: $GET_INTAKE" >&2
        exit 1
    fi
    cd "$REPO_ROOT"
    # --dj implies full intake pipeline; treat the same as --sync mode
    for __arg in "$@"; do
        [[ "$__arg" == "--dj" ]] && { MODE="sync"; break; }
        [[ "$__arg" == "--re" ]] && { RETURN_PLAYLIST=1; MODE="sync"; break; }
    done
    if [[ "$MODE" != "sync" && "$MODE" != "enrich" && "$MODE" != "backfill" ]]; then
        FORCE_NO_SKIP=0
        WRAPPER_VERBOSE=1
        FORWARD_ARGS=()
        for arg in "$@"; do
            case "$arg" in
                --force-download|--force|-f)
                    FORCE_NO_SKIP=1
                    ;;
                --verbose)
                    WRAPPER_VERBOSE=1
                    ;;
                --re)
                    RETURN_PLAYLIST=1
                    ;;
                *)
                    FORWARD_ARGS+=("$arg")
                    ;;
            esac
        done
        if [[ "$RETURN_PLAYLIST" -eq 1 ]]; then
            MODE="sync"
        fi
        if [[ "$FORCE_NO_SKIP" -eq 1 ]]; then
            FORWARD_ARGS+=(--no-skip)
        fi
        if [[ "$WRAPPER_VERBOSE" -eq 1 ]]; then
            echo "[get] routing tidal URL to tools/tiddl" >&2
        fi
        if [[ "$MODE" != "sync" ]]; then
            exec "$TIDDL_WRAPPER" "$URL" "${FORWARD_ARGS[@]+"${FORWARD_ARGS[@]}"}"
        fi
    fi
    PLAYLIST_NAME=""
    if [[ "$URL" == *"/playlist/"* ]]; then
        TIDAL_ID="${URL##*/playlist/}"
        PLAYLIST_NAME="$(cd "$REPO_ROOT" && poetry run python3 -c "
from tagslut.metadata.auth import TokenManager
import requests, json
from pathlib import Path
tm = TokenManager(Path.home() / '.config/tagslut/tokens.json')
tok = tm.get_token('tidal')
access = tok.access_token if tok else ''
if not access:
    raise SystemExit
r = requests.get(f'https://openapi.tidal.com/v2/playlists/${TIDAL_ID}',
    headers={'Authorization': f'Bearer {access}', 'Accept': 'application/vnd.api+json'}, timeout=8)
d = r.json()
print((d.get('data') or {}).get('attributes', {}).get('name', ''))
" 2>/dev/null || true)"
    elif [[ "$URL" == *"/album/"* ]]; then
        TIDAL_ID="${URL##*/album/}"
        PLAYLIST_NAME="$(cd "$REPO_ROOT" && poetry run python3 -c "
from tagslut.metadata.auth import TokenManager
import requests
from pathlib import Path
tm = TokenManager(Path.home() / '.config/tagslut/tokens.json')
tok = tm.get_token('tidal')
access = tok.access_token if tok else ''
if not access:
    raise SystemExit
r = requests.get(f'https://openapi.tidal.com/v2/albums/${TIDAL_ID}',
    headers={'Authorization': f'Bearer {access}', 'Accept': 'application/vnd.api+json'}, timeout=8)
print((r.json().get('data') or {}).get('attributes', {}).get('title', ''))
" 2>/dev/null || true)"
    fi

    if [[ -n "$PLAYLIST_NAME" ]]; then
        build_intake_cmd "tidal" "$URL" "$@" --playlist-name "$PLAYLIST_NAME"
    else
        build_intake_cmd "tidal" "$URL" "$@"
    fi
    exec "${INTAKE_CMD[@]}"

elif [[ "$URL" == *"beatport.com"* ]]; then
    # Beatport download via beatportdl — fallback for tracks only available on Beatport
    BEATPORTDL_CMD="/Users/georgeskhawam/Projects/beatportdl/beatportdl-darwin-arm64"
    if [[ ! -x "$BEATPORTDL_CMD" ]]; then
        echo "Error: beatportdl not found at $BEATPORTDL_CMD" >&2
        exit 1
    fi

    cd "$REPO_ROOT"

    # Sync fresh token from beatportdl credentials before downloading
    bash "$SCRIPT_DIR/auth" beatport 2>/dev/null

    # Run beatportdl with URL as argument (accepts positional args, no interactive prompt needed)
    cd /Users/georgeskhawam/Projects/beatportdl
    "$BEATPORTDL_CMD" "$URL"
    BEATPORT_EXIT=$?
    cd "$REPO_ROOT"

    if [[ $BEATPORT_EXIT -ne 0 ]]; then
        echo "Error: beatportdl exited with code $BEATPORT_EXIT" >&2
        exit $BEATPORT_EXIT
    fi

    # Register downloads and run enrich if requested
    BEATPORT_ROOT="/Volumes/MUSIC/staging/bpdl"
    if [[ -d "$BEATPORT_ROOT" ]]; then
        poetry run python -m tagslut index register "$BEATPORT_ROOT" --source beatport --execute
    fi

    if [[ "$WANTS_DJ" -eq 1 || "$WANTS_MP3" -eq 1 ]]; then
        MP3_ROOT_ARG="${MP3_LIBRARY:-/Volumes/MUSIC/MP3_LIBRARY}"
        INTAKE_URL_CMD=(poetry run python -m tagslut intake url "$URL")
        if [[ "$WANTS_DJ" -eq 1 ]]; then
            INTAKE_URL_CMD+=(--dj --mp3-root "$MP3_ROOT_ARG")
        else
            INTAKE_URL_CMD+=(--mp3 --mp3-root "$MP3_ROOT_ARG")
        fi
        "${INTAKE_URL_CMD[@]}"
    fi

    if [[ "$MODE" == "enrich" || "$MODE" == "auto" ]]; then
        "$SCRIPT_DIR/enrich"
    fi

elif [[ "$URL" == *"qobuz.com"* ]]; then
    # Route Qobuz URLs to streamrip
    STREAMRIP_CMD="${STREAMRIP_CMD:-/Users/georgeskhawam/Projects/streamrip/.venv/bin/rip}"
    if [[ ! -x "$STREAMRIP_CMD" ]]; then
        echo "Error: streamrip not found at $STREAMRIP_CMD" >&2
        exit 1
    fi

    STREAMRIP_CONFIG="${STREAMRIP_CONFIG:-/Users/georgeskhawam/Projects/streamrip/dev_config.toml}"
    STREAMRIP_ROOT="${STREAMRIP_ROOT:-/Volumes/MUSIC/staging/StreamripDownloads}"
    QOBUZ_BATCH_ROOT="${STREAMRIP_QOBUZ_ROOT:-$STREAMRIP_ROOT/Qobuz}"

    PLAYLIST_NAME=""
    if [[ "$URL" == *"/playlist/"* ]]; then
        PLAYLIST_ID="${URL##*/playlist/}"
        PLAYLIST_NAME="$(cd "$REPO_ROOT" && poetry run python3 -c "
from tagslut.metadata.auth import TokenManager
import requests, json
from pathlib import Path
tm = TokenManager(Path.home() / '.config/tagslut/tokens.json')
app_id, _ = tm.get_qobuz_app_credentials()
tok = tm.ensure_qobuz_token()
r = requests.get('https://www.qobuz.com/api.json/0.2/playlist/get',
    params={'playlist_id': '${PLAYLIST_ID}', 'app_id': app_id},
    headers={'X-App-Id': app_id, 'X-User-Auth-Token': tok}, timeout=8)
d = r.json()
print(d.get('name', '') or d.get('title', ''))
" 2>/dev/null || true)"
    elif [[ "$URL" == *"/album/"* ]]; then
        ALBUM_ID="${URL##*/album/}"
        PLAYLIST_NAME="$(cd "$REPO_ROOT" && poetry run python3 -c "
from tagslut.metadata.auth import TokenManager
import requests
from pathlib import Path
tm = TokenManager(Path.home() / '.config/tagslut/tokens.json')
app_id, _ = tm.get_qobuz_app_credentials()
tok = tm.ensure_qobuz_token()
r = requests.get('https://www.qobuz.com/api.json/0.2/album/get',
    params={'album_id': '${ALBUM_ID}', 'app_id': app_id},
    headers={'X-App-Id': app_id, 'X-User-Auth-Token': tok}, timeout=8)
print(r.json().get('title', ''))
" 2>/dev/null || true)"
    fi

    cd "$REPO_ROOT"
    "$STREAMRIP_CMD" --config-path "$STREAMRIP_CONFIG" --no-db url "$URL"

    STREAMRIP_EXIT=$?
    if [[ $STREAMRIP_EXIT -ne 0 ]]; then
        echo "Error: streamrip exited with code $STREAMRIP_EXIT" >&2
        exit $STREAMRIP_EXIT
    fi

    QOBUZ_INTAKE_ARGS=()
    if [[ "$MODE" == "enrich" ]]; then
        QOBUZ_INTAKE_ARGS+=(--enrich)
    fi
    QOBUZ_INTAKE_ARGS+=(--no-download --batch-root "$QOBUZ_BATCH_ROOT")

    build_intake_cmd "qobuz" "$URL" "$@" "${QOBUZ_INTAKE_ARGS[@]}"

    exec "${INTAKE_CMD[@]}"

elif [[ "$URL" == *"deezer.com"* || "$URL" == *"dzr.page.link"* ]]; then
    if [[ ! -x "$DEEMIX_WRAPPER" ]]; then
        echo "Error: deemix wrapper not found or not executable at: $DEEMIX_WRAPPER" >&2
        exit 1
    fi
    cd "$REPO_ROOT"
    exec "$DEEMIX_WRAPPER" "$URL" "$@"

else
    echo "Error: Unrecognized URL domain: $URL" >&2
    echo "Supported domains: spotify.com, tidal.com, beatport.com, deezer.com, qobuz.com" >&2
    exit 1
fi
