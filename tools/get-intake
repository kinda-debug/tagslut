import csv
import json
import sys
from pathlib import Path

source_file = Path(sys.argv[1]).expanduser()
existing_file = Path(sys.argv[2])
missing_urls_file = Path(sys.argv[3])
missing_items_file = Path(sys.argv[4])

existing = []
missing_urls = []
missing_items = []
seen_existing = set()
seen_urls = set()
seen_missing = set()

def add_existing(path_value: str) -> None:
    path_obj = Path(path_value).expanduser()
    if path_obj.is_dir():
        for child in sorted(path_obj.rglob("*.flac")):
            resolved = str(child.resolve())
            if resolved not in seen_existing:
                seen_existing.add(resolved)
                existing.append(resolved)
        return
    if path_obj.exists() and path_obj.suffix.lower() == ".flac":
        resolved = str(path_obj.resolve())
        if resolved not in seen_existing:
            seen_existing.add(resolved)
            existing.append(resolved)
        return
    missing = str(path_obj)
    if missing not in seen_missing:
        seen_missing.add(missing)
        missing_items.append(missing)

def add_url(url: str) -> None:
    if url not in seen_urls:
        seen_urls.add(url)
        missing_urls.append(url)

def consume_item(value: str) -> None:
    item = (value or "").strip()
    if not item:
        return
    if item.startswith("#"):
        return
    if item.startswith("http://") or item.startswith("https://"):
        add_url(item)
    else:
        add_existing(item)

suffix = source_file.suffix.lower()
if suffix in {".m3u", ".m3u8", ".txt"}:
    for line in source_file.read_text(encoding="utf-8", errors="replace").splitlines():
        consume_item(line)
elif suffix == ".csv":
    with source_file.open(newline="", encoding="utf-8", errors="replace") as handle:
        reader = csv.DictReader(handle)
        if reader.fieldnames:
            for row in reader:
                consumed = False
                for key in ("path", "file", "filepath", "location", "url", "uri"):
                    if key in row and (row.get(key) or "").strip():
                        consume_item(row.get(key) or "")
                        consumed = True
                if not consumed and row:
                    first_value = next(iter(row.values()), "")
                    consume_item(first_value or "")
        else:
            handle.seek(0)
            for row in csv.reader(handle):
                if row:
                    consume_item(row[0])
elif suffix == ".json":
    payload = json.loads(source_file.read_text(encoding="utf-8", errors="replace"))
    queue = [payload]
    while queue:
        current = queue.pop(0)
        if isinstance(current, str):
            consume_item(current)
        elif isinstance(current, list):
            queue.extend(current)
        elif isinstance(current, dict):
            for key in ("path", "file", "filepath", "location", "url", "uri"):
                if key in current:
                    queue.append(current[key])
            for value in current.values():
                if isinstance(value, (list, dict)):
                    queue.append(value)
else:
    consume_item(str(source_file))

for path in (existing_file, missing_urls_file, missing_items_file):
    path.parent.mkdir(parents=True, exist_ok=True)
existing_file.write_text("\n".join(existing) + ("\n" if existing else ""), encoding="utf-8")
missing_urls_file.write_text("\n".join(missing_urls) + ("\n" if missing_urls else ""), encoding="utf-8")
missing_items_file.write_text("\n".join(missing_items) + ("\n" if missing_items else ""), encoding="utf-8")
PY
