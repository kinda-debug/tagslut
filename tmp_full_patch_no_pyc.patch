-                    stdout=subprocess.DEVNULL,
-                    stderr=subprocess.DEVNULL,
-                    timeout=timeout_per_window,
-                    check=False,
-                )
-            except subprocess.TimeoutExpired:
-                break
-
-            if tmp_path.exists() and tmp_path.stat().st_size > 0:
-                try:
-                    proc = subprocess.run(
-                        [fpcalc, str(tmp_path)],
