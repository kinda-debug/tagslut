import csv
import json
import sys
from pathlib import Path

source_file = Path(sys.argv[1]).expanduser()
existing_file = Path(sys.argv[2])
missing_urls_file = Path(sys.argv[3])
missing_items_file = Path(sys.argv[4])

existing = []
missing_urls = []
missing_items = []
seen_existing = set()
seen_urls = set()
seen_missing = set()

def add_existing(path_value: str) -> None:
    path_obj = Path(path_value).expanduser()
    if path_obj.is_dir():
        for child in sorted(path_obj.rglob("*.flac")):
            resolved = str(child.resolve())
            if resolved not in seen_existing:
                seen_existing.add(resolved)
                existing.append(resolved)
        return
    if path_obj.exists() and path_obj.suffix.lower() == ".flac":
        resolved = str(path_obj.resolve())
        if resolved not in seen_existing:
            seen_existing.add(resolved)
            existing.append(resolved)
        return
    missing = str(path_obj)
    if missing not in seen_missing:
        seen_missing.add(missing)
        missing_items.append(missing)

def add_url(url: str) -> None:
    if url not in seen_urls:
        seen_urls.add(url)
        missing_urls.append(url)

def consume_item(value: str) -> None:
    item = (value or "").strip()
    if not item:
        return
    if item.startswith("#"):
        return
    if item.startswith("http://") or item.startswith("https://"):
        add_url(item)
    else:
        add_existing(item)

