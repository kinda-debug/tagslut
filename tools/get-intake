                SELECT al.identity_id
                FROM asset_file af
                JOIN asset_link al ON al.asset_id = af.id
                WHERE af.path = ?
                {active_where}
                ORDER BY al.id ASC
                LIMIT 1
                """,
                (path,),
            ).fetchone()

        row = _resolve(text)
        if row is None:
            prior = dest_to_src.get(text)
            if prior:
                row = _resolve(prior)
        if row is None:
            continue
        identity_id = int(row[0])
        if identity_id in seen:
            continue
        seen.add(identity_id)
        selected.append(identity_id)
finally:
    conn.close()

out_file.write_text(
    "\n".join(str(item) for item in selected) + ("\n" if selected else ""),
    encoding="utf-8",
)
print(f"Resolved {len(selected)} promoted identity ids")
PY

