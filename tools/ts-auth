#!/usr/bin/env bash
set -euo pipefail

# Repo-local auth wrapper. Available on PATH after `source START_HERE.sh`.
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_wrapper_common.sh"
ts_wrapper_bootstrap "${BASH_SOURCE[0]}"
PROVIDER="${1:-all}"
if [ "$#" -gt 0 ]; then
    shift
fi
exec "$TAGSLUT_TOOLS_DIR/tagslut" auth login "$PROVIDER" "$@"
