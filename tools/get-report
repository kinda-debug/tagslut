#!/usr/bin/env bash
# get-report — Beatport URL -> report-only playlist pass (no download)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GET_INTAKE="$SCRIPT_DIR/get-intake"

usage() {
  echo "Usage: tools/get-report <beatport-url> [extra get-intake args...]"
  exit 1
}

if [[ $# -lt 1 ]]; then
  usage
fi

URL="$1"
shift

if [[ "$URL" != *"beatport.com"* ]]; then
  echo "Error: tools/get-report only supports beatport.com URLs" >&2
  exit 2
fi

exec "$GET_INTAKE" "$URL" --missing-policy report "$@"
