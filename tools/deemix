#!/usr/bin/env bash
# deemix — Wrapper script for system-installed deemix
#
# Defaults:
# - bitrate: FLAC
# - path: ~/Music/mdl/deezer (override with --path or DEEMIX_PATH)
#
# After successful download, auto-registers to inventory:
#   tagslut index register <path> --source deezer --execute

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DEEMIX_BIN="${DEEMIX_BIN:-/opt/homebrew/bin/deemix}"
DEEMIX_PATH="${DEEMIX_PATH:-$HOME/Music/mdl/deezer}"
AUTO_REGISTER="${DEEMIX_AUTO_REGISTER:-1}"
DB_PATH="${DEDUPE_DB:-}"

if [[ ! -x "$DEEMIX_BIN" ]]; then
    if command -v deemix >/dev/null 2>&1; then
        DEEMIX_BIN="$(command -v deemix)"
    else
        echo "Error: deemix binary not found: $DEEMIX_BIN" >&2
        echo "Set DEEMIX_BIN or install deemix in PATH." >&2
        exit 1
    fi
fi

ARGS=("$@")
HAS_PATH=0
HAS_BITRATE=0
SHOW_ONLY=0
DOWNLOAD_PATH="$DEEMIX_PATH"

for ((i=0; i<${#ARGS[@]}; i++)); do
    if [[ "${ARGS[$i]}" == "--path" ]]; then
        HAS_PATH=1
        if [[ $((i+1)) -lt ${#ARGS[@]} ]]; then
            DOWNLOAD_PATH="${ARGS[$((i+1))]}"
        fi
    fi
    if [[ "${ARGS[$i]}" == "--bitrate" ]]; then
        HAS_BITRATE=1
    fi
    if [[ "${ARGS[$i]}" == "--help" || "${ARGS[$i]}" == "-h" ]]; then
        SHOW_ONLY=1
    fi
done

if [[ "$HAS_BITRATE" -eq 0 ]]; then
    ARGS=(--bitrate FLAC "${ARGS[@]}")
fi

if [[ "$HAS_PATH" -eq 0 ]]; then
    ARGS=(--path "$DEEMIX_PATH" "${ARGS[@]}")
    DOWNLOAD_PATH="$DEEMIX_PATH"
fi

mkdir -p "$DOWNLOAD_PATH"

echo "→ Running deemix..."
printf '→ %q ' "$DEEMIX_BIN" "${ARGS[@]}"
printf '\n'
"$DEEMIX_BIN" "${ARGS[@]}"

if [[ "$AUTO_REGISTER" == "1" && "$SHOW_ONLY" == "0" ]]; then
    if command -v poetry >/dev/null 2>&1; then
        echo "→ Registering downloaded files to DB as source=deezer..."
        cd "$REPO_ROOT"
        if [[ -n "$DB_PATH" ]]; then
            poetry run tagslut index register "$DOWNLOAD_PATH" --source deezer --db "$DB_PATH" --execute || true
        else
            poetry run tagslut index register "$DOWNLOAD_PATH" --source deezer --execute || true
        fi
    else
        echo "Warning: poetry not found; skipping auto-register." >&2
    fi
fi
