#!/usr/bin/env bash
# get-intake — advanced/backend intake pipeline for downloaded batches
#
# This is the lower-level engine behind tools/get.
#
# Pipeline:
#  1) Download via provider downloader (optional)
#  2) Quick duplicate check via tagslut index check (strict, non-interactive)
#  3) Fast trust scan + integrity registration
#  4) Cross-root fingerprint audit against final library
#  5) Build promote/fix/quarantine/discard plans
#  6) Optionally execute move plans (move-only semantics)
#
# Default behavior is safe: plans only (no moves) unless --execute is passed.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_LOADER="$SCRIPT_DIR/_load_env.sh"

USE_COLOR=0
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  USE_COLOR=1
fi
CLR_RESET=$'\033[0m'
CLR_BOLD=$'\033[1m'
CLR_DIM=$'\033[2m'
CLR_RED=$'\033[31m'
CLR_GREEN=$'\033[32m'
CLR_YELLOW=$'\033[33m'
CLR_CYAN=$'\033[36m'

clr() {
  local code="$1"
  shift
  if [[ "$USE_COLOR" -eq 1 ]]; then
    printf '%s%s%s' "$code" "$*" "$CLR_RESET"
  else
    printf '%s' "$*"
  fi
}

if [[ -f "$ENV_LOADER" ]]; then
  # shellcheck disable=SC1090
  source "$ENV_LOADER"
  load_workspace_env "$REPO_ROOT"
fi

GET_BIN="$SCRIPT_DIR/get"
TIDDL_WRAPPER="$SCRIPT_DIR/tiddl"
SCAN_SCRIPT="$SCRIPT_DIR/review/scan_with_trust.py"
AUDIT_SCRIPT="$SCRIPT_DIR/review/audio_dupe_audit.py"
PLAN_SCRIPT="$SCRIPT_DIR/review/plan_fpcalc_promote_unique_to_final_library.py"
MOVE_SCRIPT="$SCRIPT_DIR/review/move_from_plan.py"
PROCESS_ROOT_SCRIPT="$SCRIPT_DIR/review/process_root.py"
PRE_DOWNLOAD_CHECK_SCRIPT="$SCRIPT_DIR/review/pre_download_check.py"
POST_MOVE_ENRICH_SCRIPT="$SCRIPT_DIR/review/post_move_enrich_art.py"
BUILD_POOL_V3_SCRIPT="$REPO_ROOT/scripts/dj/build_pool_v3.py"
PLAN_SKIPPED_SCRIPT="$SCRIPT_DIR/review/plan_move_skipped.py"
AUTO_DB_AMBIGUOUS=0
AUTO_DB_CANDIDATES=()

usage() {
  cat <<'EOF'
Usage:
  tools/get-intake [options] <url> [-- downloader-args...]
  tools/get-intake --no-download --batch-root <path> [options]
  tools/get-intake --m3u-only (--url <url> | --playlist-file <file>) [options]
  tools/get-intake <provider-url>   # auto: use provider download root when --batch-root omitted

Note:
  tools/get is the primary user-facing downloader.
  tools/get-intake is the advanced/backend command for existing batch roots,
  m3u-only workflows, and direct pipeline control.

Options:
  --batch-root PATH    Download batch root to process (default: $ROOT_TD or $VOLUME_STAGING/tidal)
  --source TEXT        Source label (tidal/spotify). Auto-inferred from URL if omitted.
  --url URL            Source URL (alternative to positional URL)
  --db PATH            SQLite DB path (default: $TAGSLUT_DB or auto-detected tagslut_db epoch; errors if ambiguous)
  --library-root PATH  Final library root (default: $LIBRARY_ROOT or $VOLUME_LIBRARY or $MASTER_LIBRARY)
  --fix-root PATH      FIX root for salvageable metadata issues (default: $FIX_ROOT or $VOLUME_WORK/fix)
  --quarantine-root PATH
                       Quarantine root for risky files (default: $QUARANTINE_ROOT or $VOLUME_QUARANTINE)
  --discard-root PATH  Discard root for deterministic duplicates like dest_exists (default: $DISCARD_ROOT or $VOLUME_WORK/discard)
  --out-dir PATH       Output directory for plans (default: $TAGSLUT_ARTIFACTS/compare or artifacts/compare)
  --workers N          Fingerprint workers (default: 7)
  --trust N            Pre-scan trust score 0..3 (default: 3)
  --trust-post N       Post-scan trust score 0..3 (default: 3)
  --library-tag TEXT   Library tag used in scan_with_trust (default: INTAKE)
  --providers TEXT     Metadata providers for enrichment
  --verbose            Print internal paths, artifacts, and batch snapshots
  --execute            Execute move plans (default: dry-run planning only)
  --m3u                Generate Roon-friendly merged M3U from promoted files
  --m3u-dir PATH       M3U output dir (default: $PLAYLIST_ROOT or library root)
  --dj                 Build MP3_LIBRARY copies and DJ pool M3U playlists
  --dj-m3u-dir PATH    DJ playlist output dir (default: $DJ_PLAYLIST_ROOT or MP3 root)
  --m3u-only           Only generate merged M3U (skip download/scan/move stages)
  --playlist-file PATH Build M3U from playlist file (.m3u/.m3u8/.txt/.csv/.json)
  --missing-policy MODE
                       Missing handling for --m3u-only: ask|report|skip|download (default: report)
  --no-download        Skip downloader step; process existing batch root
  --skip-mgmt-check    Skip quick duplicate check stage (legacy flag name)
  --enrich             Explicit alias for tagging/enrich/art pipeline (default)
  --hoard              Deprecated alias for --enrich
  --no-tagging         Skip tagging / metadata enrich / cover-art steps
  --no-precheck        Skip pre-download DB check for Tidal/Beatport/Spotify URLs
  --resume             Resume: treat existing batch-root files as already acquired (ISRC-only)
  --force-download     Keep matched tracks instead of skipping same/better inventory matches
  --skip-beatport-prefilter
                       Deprecated alias for --no-precheck
  -h, --help           Show this help

Examples:
  tools/get-intake --no-download --batch-root "$STAGING_ROOT/clean" --execute

EOF
}

err() {
  echo "ERROR: $*" >&2
  exit 2
}

step() {
  local idx="$1"
  local total="$2"
  local label="$3"
  echo
  printf '%s %s\n' "$(clr "$CLR_CYAN" "[$idx/$total]")" "$(clr "$CLR_BOLD" "$label")"
}

run_cmd() {
  local max_args="${GET_INTAKE_MAX_PRINT_ARGS:-12}"
  printf '%s ' "$(clr "$CLR_DIM" "→")"
  if [[ "${VERBOSE:-0}" -eq 1 ]]; then
    printf '%q ' "$@"
  else
    local shown=0
    for arg in "$@"; do
      if [[ "$shown" -ge "$max_args" ]]; then
        break
      fi
      printf '%q ' "$arg"
      shown=$((shown + 1))
    done
    if [[ "$#" -gt "$max_args" ]]; then
      printf '%s' "$(clr "$CLR_DIM" "…(+$(( $# - max_args )) args)")"
    fi
  fi
  printf '\n'
  "$@"
}

run_cmd_in_dir() {
  local workdir="$1"
  shift
  local max_args="${GET_INTAKE_MAX_PRINT_ARGS:-12}"
  printf '%s ' "$(clr "$CLR_DIM" "→")"
  if [[ "${VERBOSE:-0}" -eq 1 ]]; then
    printf '%q ' "$@"
  else
    local shown=0
    for arg in "$@"; do
      if [[ "$shown" -ge "$max_args" ]]; then
        break
      fi
      printf '%q ' "$arg"
      shown=$((shown + 1))
    done
    if [[ "$#" -gt "$max_args" ]]; then
      printf '%s' "$(clr "$CLR_DIM" "…(+$(( $# - max_args )) args)")"
    fi
  fi
  printf '\n'
  env -C "$workdir" "$@"
}

resolved_volume_path() {
  local volume_name="$1"
  python3 - "$volume_name" <<'PY'
from __future__ import annotations

import sys
import warnings

try:
    from tagslut.utils import env_paths
except Exception:
    print("")
    raise SystemExit(0)

name = sys.argv[1]
with warnings.catch_warnings(record=True) as caught:
    warnings.simplefilter("default", DeprecationWarning)
    value = env_paths.get_volume(name)

for item in caught:
    print(f"WARNING: {item.message}", file=sys.stderr)

print("" if value is None else str(value))
PY
}

RESOLVED_STAGING_ROOT_CACHE=""
RESOLVED_STAGING_ROOT_CACHE_SET=0

resolved_staging_root() {
  if [[ "${RESOLVED_STAGING_ROOT_CACHE_SET:-0}" -eq 1 ]]; then
    printf '%s\n' "$RESOLVED_STAGING_ROOT_CACHE"
    return 0
  fi
  local staging_root=""
  staging_root="$(resolved_volume_path staging || true)"
  if [[ -z "$staging_root" ]]; then
    staging_root="$(first_nonempty \
      "${STAGING_ROOT:-}" \
      "${VOLUME_STAGING:-}" || true)"
  fi
  RESOLVED_STAGING_ROOT_CACHE="$staging_root"
  RESOLVED_STAGING_ROOT_CACHE_SET=1
  printf '%s\n' "$RESOLVED_STAGING_ROOT_CACHE"
}

precheck_candidate_quality_rank() {
  if [[ -n "${PRECHECK_CANDIDATE_QUALITY_RANK:-}" ]]; then
    printf '%s\n' "$PRECHECK_CANDIDATE_QUALITY_RANK"
    return 0
  fi

  case "${SOURCE:-}" in
    tidal)
      # Tidal max quality is not knowable pre-download; default conservatively to CD lossless.
      printf '%s\n' "${TIDAL_PRECHECK_CANDIDATE_QUALITY_RANK:-4}"
      ;;
    spotify)
      printf '%s\n' "${SPOTIFY_PRECHECK_CANDIDATE_QUALITY_RANK:-4}"
      ;;
    *)
      printf '3\n'
      ;;
  esac
}

cross_root_audit_scope() {
  local scope="${GET_INTAKE_CROSS_ROOT_AUDIT_SCOPE:-batch_only}"
  case "$scope" in
    batch_only|all_roots)
      printf '%s\n' "$scope"
      ;;
    *)
      err "Invalid GET_INTAKE_CROSS_ROOT_AUDIT_SCOPE=$scope (expected: batch_only|all_roots)"
      ;;
  esac
}

cross_root_audit_compute_root_args() {
  local scope
  scope="$(cross_root_audit_scope)"
  case "$scope" in
    batch_only)
      [[ -n "${BATCH_ROOT:-}" ]] || err "BATCH_ROOT is required for batch-only cross-root audit"
      printf '%s\n' "--compute-root" "$BATCH_ROOT"
      ;;
    all_roots)
      ;;
  esac
}

link_precheck_inventory_to_dj() {
  local decisions_csv="${1:-}"
  local playlist_title="${2:-}"
  [[ -n "$decisions_csv" && -f "$decisions_csv" ]] || return 0
  [[ "${DJ_MODE:-0}" -eq 1 ]] || return 0

  local name_hint="${M3U_NAME_HINT:-}"
  if [[ -z "$name_hint" ]]; then
    name_hint="$(safe_m3u_name "${playlist_title:-precheck-inventory}")"
  fi
  local playlist_base_name="${DJ_PLAYLIST_PREFIX}${name_hint}${DJ_PLAYLIST_SUFFIX}"
  local artifact_dir="$OUT_DIR/precheck_inventory_dj_$(date +%Y%m%d_%H%M%S)"

  run_cmd poetry run python -m tagslut.exec.precheck_inventory_dj \
    --db "$DB_PATH" \
    --decisions-csv "$decisions_csv" \
    --dj-root "$DJ_ROOT" \
    --playlist-dir "$DJ_M3U_DIR" \
    --playlist-base-name "$playlist_base_name" \
    --artifact-dir "$artifact_dir"

  if [[ -f "$DJ_M3U_DIR/$playlist_base_name.m3u" ]]; then
    DJ_M3U_OUTPUT="$DJ_M3U_DIR/$playlist_base_name.m3u"
    echo "Inventory-backed DJ playlist: $DJ_M3U_OUTPUT"
  fi
}

run_tiddl_download() {
  local tidal_url="${1:-}"
  shift || true

  local cmd=("$TIDDL_WRAPPER")
  local has_no_skip=0
  if [[ $# -gt 0 ]]; then
    for arg in "$@"; do
      if [[ "$arg" == "--no-skip" || "$arg" == "-ns" ]]; then
        has_no_skip=1
        break
      fi
    done
    cmd+=("$@")
  fi
  if [[ "${FORCE_DOWNLOAD:-0}" -eq 1 && "$has_no_skip" -eq 0 ]]; then
    cmd+=(--no-skip)
  fi
  cmd+=(--path "$BATCH_ROOT" --scan-path "$BATCH_ROOT" --skip-errors "$tidal_url")

  printf '→ '
  printf '%q ' "${cmd[@]}"
  printf '\n'
  "${cmd[@]}"
}

run_spotify_download() {
  local spotify_url="${1:-}"
  local keep_urls_file="${2:-}"
  local stamp
  stamp="$(date +%Y%m%d_%H%M%S)"
  SPOTIFY_MANIFEST_FILE="$OUT_DIR/spotify_acquisition_manifest_${stamp}.json"

  local cmd=(
    python
    -m
    tagslut.intake.spotify
    --url "$spotify_url"
    --batch-root "$BATCH_ROOT"
    --out-dir "$OUT_DIR"
    --repo-root "$REPO_ROOT"
    --manifest-path "$SPOTIFY_MANIFEST_FILE"
  )
  if [[ -n "$keep_urls_file" && -f "$keep_urls_file" ]]; then
    cmd+=(--keep-track-url-file "$keep_urls_file")
  fi
  run_cmd_in_dir "$REPO_ROOT" "${cmd[@]}"
}

count_audio_files() {
  local root="${1:-}"
  if [[ -z "$root" || ! -d "$root" ]]; then
    echo "0"
    return 0
  fi
  find "$root" -type f \( \
    -iname '*.flac' -o \
    -iname '*.mp3' -o \
    -iname '*.wav' -o \
    -iname '*.aif' -o \
    -iname '*.aiff' -o \
    -iname '*.m4a' \
  \) | wc -l | tr -d ' '
}

write_audio_file_list() {
  local root="${1:-}"
  local out_path="${2:-}"
  if [[ -z "$root" || ! -d "$root" || -z "$out_path" ]]; then
    return 0
  fi
  mkdir -p "$(dirname "$out_path")"
  find "$root" -type f \( \
    -iname '*.flac' -o \
    -iname '*.mp3' -o \
    -iname '*.wav' -o \
    -iname '*.aif' -o \
    -iname '*.aiff' -o \
    -iname '*.m4a' \
  \) | sort > "$out_path"
}

emit_batch_leftovers_report() {
  local root="${1:-}"
  local report_path="${2:-}"
  local leftover_count="0"

  if [[ -z "$root" || ! -d "$root" ]]; then
    echo "Batch leftovers: root unavailable"
    return 0
  fi

  leftover_count="$(count_audio_files "$root")"
  if [[ "$leftover_count" -eq 0 ]]; then
    echo "Batch leftovers: none"
    return 0
  fi

  if [[ -z "$report_path" ]]; then
    report_path="${OUT_DIR:-$REPO_ROOT/artifacts/compare}/batch_leftovers_$(date +%Y%m%d_%H%M%S).txt"
  fi

  write_audio_file_list "$root" "$report_path"

  echo "Batch leftovers: $leftover_count"
  echo "  report: $report_path"
  if [[ "${VERBOSE:-0}" -eq 1 ]]; then
    echo "Batch leftovers preview:"
    preview_file_lines "$report_path" 5
  fi
}

preview_file_lines() {
  local path="${1:-}"
  local limit="${2:-5}"
  if [[ -z "$path" || ! -f "$path" ]]; then
    return 0
  fi
  awk -v limit="$limit" 'NF {print "    " $0; shown += 1; if (shown >= limit) exit}' "$path"
}

print_batch_snapshot() {
  local label="${1:-Batch}"
  local root="${2:-}"
  if [[ -z "$root" ]]; then
    echo "$label: root unset"
    return 0
  fi
  if [[ ! -d "$root" ]]; then
    echo "$label: missing ($root)"
    return 0
  fi

  local audio_count
  local flac_count
  local mp3_count
  audio_count="$(count_audio_files "$root")"
  flac_count="$(find "$root" -type f -iname '*.flac' | wc -l | tr -d ' ')"
  mp3_count="$(find "$root" -type f -iname '*.mp3' | wc -l | tr -d ' ')"

  echo "$label: root=$root audio=$audio_count flac=$flac_count mp3=$mp3_count"
  local sample_file=""
  while IFS= read -r sample_file; do
    [[ -n "$sample_file" ]] || continue
    echo "    $sample_file"
  done < <(find "$root" -type f \( \
      -iname '*.flac' -o \
      -iname '*.mp3' -o \
      -iname '*.wav' -o \
      -iname '*.aif' -o \
      -iname '*.aiff' -o \
      -iname '*.m4a' \
    \) | sort | tail -n 5)
}

safe_m3u_name() {
  local value="${1:-}"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9._-]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g')"
  [[ -n "$value" ]] || value="playlist"
  echo "$value"
}

playlist_label_from_url() {
  local clean="${1%%\?*}"
  clean="${clean%/}"
  local last="${clean##*/}"
  local parent="${clean%/*}"
  local slug="${parent##*/}"

  case "$slug" in
    chart|release|releases|playlist|playlists|track|tracks|library|"")
      slug=""
      ;;
  esac

  if [[ -z "$slug" ]]; then
    slug="beatport-${last:-playlist}"
  fi
  safe_m3u_name "$slug"
}

is_playlist_url() {
  local clean="${1%%\?*}"
  [[ "$clean" == *"/playlist/"* || "$clean" == *"/playlists/"* ]]
}

playlist_name_hint_from_tracks_csv() {
  local tracks_csv="${1:-}"
  local source_url="${2:-}"
  [[ -f "$tracks_csv" ]] || return 0

  python3 - "$tracks_csv" "$source_url" <<'PY'
import csv
import sys
from pathlib import Path

tracks_csv = Path(sys.argv[1])
source_url = (sys.argv[2] or "").strip()

with tracks_csv.open(newline="", encoding="utf-8") as handle:
    reader = csv.DictReader(handle)
    for row in reader:
        link_type = (row.get("link_type") or "").strip().lower()
        row_url = (row.get("source_link") or "").strip()
        link_title = (row.get("link_title") or "").strip()
        if "playlist" not in link_type:
            continue
        if source_url and row_url and row_url != source_url:
            continue
        if link_title:
            print(link_title)
            raise SystemExit(0)
print("")
PY
}

rename_latest_m3u_from_marker() {
  local m3u_dir="$1"
  local marker_file="$2"
  local base_name="$3"
  local name_prefix="${4:-}"
  local name_suffix="${5:-}"

  [[ -d "$m3u_dir" ]] || return 0
  [[ -f "$marker_file" ]] || return 0
  [[ -n "$base_name" ]] || return 0

  local latest_new_m3u
  latest_new_m3u="$(find "$m3u_dir" -maxdepth 1 -type f -name '*.m3u' -newer "$marker_file" -print | sort | tail -n1 || true)"
  [[ -n "$latest_new_m3u" ]] || return 0

  local target="$m3u_dir/${name_prefix}${base_name}${name_suffix}.m3u"
  if [[ "$latest_new_m3u" != "$target" ]]; then
    if [[ -f "$latest_new_m3u" ]]; then
      if mv -f "$latest_new_m3u" "$target"; then
        echo "Named playlist: $target"
      else
        echo "ERROR: Failed to rename M3U $latest_new_m3u → $target" >&2
      fi
    fi
  fi
}

latest_file_after_marker() {
  local search_dir="$1"
  local marker_file="$2"
  local pattern="${3:-*.m3u}"

  [[ -d "$search_dir" ]] || return 0
  [[ -f "$marker_file" ]] || return 0
  find "$search_dir" -maxdepth 1 -type f -name "$pattern" -newer "$marker_file" -print | sort | tail -n1 || true
}

tiddl_downloads_dir_from_config() {
  local cfg=""
  local kind="json"
  local candidate=""
  for candidate in "$HOME/.tiddl/config.toml" "$HOME/tiddl.json" "$HOME/Documents/tiddl.json"; do
    if [[ -f "$candidate" ]]; then
      cfg="$candidate"
      if [[ "$candidate" == *.toml ]]; then
        kind="toml"
      fi
      break
    fi
  done
  if [[ -z "$cfg" ]]; then
    echo ""
    return 0
  fi
  python3 - "$cfg" "$kind" <<'PY'
import sys
from pathlib import Path
import json
import tomllib

cfg = Path(sys.argv[1]).expanduser()
kind = sys.argv[2]
try:
    if kind == "toml":
        payload = tomllib.loads(cfg.read_text(encoding="utf-8"))
    else:
        payload = json.loads(cfg.read_text(encoding="utf-8"))
except Exception:
    print("")
    raise SystemExit(0)

download = payload.get("download") or {}
print(download.get("path") or download.get("download_path") or "")
PY
}

first_nonempty() {
  local value=""
  for value in "$@"; do
    if [[ -n "${value:-}" ]]; then
      printf '%s\n' "$value"
      return 0
    fi
  done
  return 1
}

path_candidate_is_usable() {
  local candidate="${1:-}"
  [[ -n "$candidate" ]] || return 1
  if [[ "$candidate" == /Volumes/* ]]; then
    local remainder="${candidate#/Volumes/}"
    local volume_name="${remainder%%/*}"
    [[ -n "$volume_name" ]] || return 1
    [[ -d "/Volumes/$volume_name" ]] || return 1
  fi
  return 0
}

first_usable_path() {
  local candidate=""
  for candidate in "$@"; do
    [[ -n "${candidate:-}" ]] || continue
    if path_candidate_is_usable "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

resolve_path() {
  python3 - "$1" <<'PY'
from pathlib import Path
import sys

print(Path(sys.argv[1]).expanduser().resolve())
PY
}

