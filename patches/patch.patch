-    try:
-        cur = conn.cursor()
-        cur.execute(
-            """
-            CREATE TABLE file_hashes (
-                file_path TEXT PRIMARY KEY,
-                file_md5 TEXT NOT NULL,
-                file_size INTEGER,
-                scan_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP
-            )
-            """
-        )
-        cur.executemany(
-            (
-                "INSERT INTO file_hashes(file_path, file_md5, file_size) "
-                "VALUES(?,?,?)"
