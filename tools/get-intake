    with source_file.open(newline="", encoding="utf-8", errors="replace") as handle:
        reader = csv.DictReader(handle)
        if reader.fieldnames:
            for row in reader:
                consumed = False
                for key in ("path", "file", "filepath", "location", "url", "uri"):
                    if key in row and (row.get(key) or "").strip():
                        consume_item(row.get(key) or "")
                        consumed = True
                if not consumed and row:
                    first_value = next(iter(row.values()), "")
                    consume_item(first_value or "")
        else:
            handle.seek(0)
            for row in csv.reader(handle):
                if row:
                    consume_item(row[0])
elif suffix == ".json":
    payload = json.loads(source_file.read_text(encoding="utf-8", errors="replace"))
