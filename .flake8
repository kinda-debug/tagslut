[flake8]
exclude =
    tagslut/ARCHIVE,
    .venv,
    .git,
    __pycache__,
    build,
    dist
extend-exclude =
    tagslut/storage/v3/migrations,
    tagslut/storage/v3/legacy,
    tagslut/storage/v2
max-line-length = 120
extend-ignore = E203, W503
base-packages = tagslut
custom-restrictions =
    tagslut.core:tagslut.dj
    tagslut.dj:tagslut.core

# Debt-heavy modules are temporarily excluded from CI linting.
# Staged cleanup is tracked in docs/ACTION_PLAN.md.
